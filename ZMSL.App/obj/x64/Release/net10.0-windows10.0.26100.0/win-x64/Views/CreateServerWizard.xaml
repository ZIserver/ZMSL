<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="ZMSL.App.Views.CreateServerWizard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        >

    <Grid Padding="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Border Background="{ThemeResource AccentFillColorDefaultBrush}" 
                        CornerRadius="8" Width="40" Height="40" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE710;" Foreground="White" FontSize="20"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:ConnectionId='15' x:Name="StepTitle" Text="创建服务器" FontSize="20" FontWeight="Bold"/>
                    <TextBlock x:ConnectionId='16' x:Name="StepSubtitle" Text="选择创建模式" FontSize="12" Opacity="0.6"/>
                </StackPanel>
            </StackPanel>
            
            <!-- 步骤指示器 -->
            <StackPanel x:ConnectionId='11' x:Name="StepIndicatorPanel" Grid.Column="2" Orientation="Horizontal" 
                       Spacing="6" VerticalAlignment="Center">
                <Border x:ConnectionId='12' x:Name="Step1Indicator" Width="28" Height="3" Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="1.5"/>
                <Border x:ConnectionId='13' x:Name="Step2Indicator" Width="28" Height="3" Background="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="1.5"/>
                <Border x:ConnectionId='14' x:Name="Step3Indicator" Width="28" Height="3" Background="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="1.5"/>
            </StackPanel>
        </Grid>

        <!-- 内容区域 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid MaxWidth="800" HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- 左侧：核心列表 -->
                <StackPanel Grid.Column="0" Spacing="8">
                    <TextBlock Text="核心列表" FontSize="13" FontWeight="SemiBold" Opacity="0.7" Margin="0,0,0,8"/>
                    <ScrollViewer MaxHeight="400" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:ConnectionId='9' x:Name="CoreTypesPanel">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button x:ConnectionId='10'                        Tag="{Binding Name}" 
                                            HorizontalAlignment="Stretch" Padding="12,8" Margin="0,0,0,4"
                                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1" CornerRadius="6">
                                        <TextBlock Text="{Binding DisplayName}" FontSize="13"/>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
                
                <!-- 右侧：版本列表 -->
                <StackPanel Grid.Column="2" Spacing="12">
                    <TextBlock x:ConnectionId='5' x:Name="SelectedCoreText" Text="请选择核心" FontSize="13" FontWeight="SemiBold" Opacity="0.7" Margin="0,0,0,8"/>
                    
                    <!-- 版本列表 -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            CornerRadius="8" Padding="16" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock Text="可用版本" FontSize="13" FontWeight="SemiBold"/>
                            <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:ConnectionId='7' x:Name="VersionListView">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button x:ConnectionId='8'                       Tag="{Binding}" 
                                                    HorizontalAlignment="Stretch" Padding="12,8" Margin="0,0,0,4"
                                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    BorderThickness="1" CornerRadius="6">
                                                <TextBlock Text="{Binding}" FontSize="13"/>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                    
                    <!-- 空状态提示 -->
                    <StackPanel x:ConnectionId='6' x:Name="EmptyVersionHint" 
                               HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                        <FontIcon Glyph="&#xE8F3;" FontSize="32" Opacity="0.2"/>
                        <TextBlock Text="请先选择核心查看版本" FontSize="12" Opacity="0.4"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- 底部按钮栏 -->
        <Grid Grid.Row="2" Margin="0,16,0,0" 
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
              BorderThickness="0,1,0,0" Padding="16">
            <Grid MaxWidth="800" HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:ConnectionId='3'                          Padding="16,10">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                            <TextBlock Text="返回" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button x:ConnectionId='4'                            Padding="16,10">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE711;" FontSize="14"/>
                            <TextBlock Text="取消" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                
                <Button x:ConnectionId='2' x:Name="NextButton" Grid.Column="1"
                                                 
                        Style="{StaticResource AccentButtonStyle}" 
                        Padding="24,10" MinWidth="120">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="创建服务器" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <FontIcon Glyph="&#xE72A;" FontSize="14"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</Page>

