<Page x:ConnectionId='1'
    x:Class="ZMSL.App.Views.DocumentationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:ZMSL.App.ViewModels"
    xmlns:local="using:ZMSL.App.Views"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧导航 -->
        <NavigationView x:ConnectionId='2' x:Name="DocNav" 
                        PaneDisplayMode="Left" 
                        IsBackButtonVisible="Collapsed" 
                        IsSettingsVisible="False"
                        IsPaneOpen="True"
                        OpenPaneLength="200"
                                                                          >
            <NavigationView.MenuItems>
                <NavigationViewItem Content="快速入门" Tag="GettingStarted" Icon="Home"/>
                <NavigationViewItem Content="服务器管理" Tag="ServerManagement" Icon="Manage"/>
                <NavigationViewItem Content="进阶功能" Tag="AdvancedFeatures" Icon="Repair"/>
                <NavigationViewItem Content="社区与支持" Tag="Community" Icon="People"/>
            </NavigationView.MenuItems>
        </NavigationView>

        <!-- 右侧内容 -->
        <ScrollViewer Grid.Column="1" Padding="24,12,24,24">
            <StackPanel Spacing="20" MaxWidth="1000" HorizontalAlignment="Left">
                <!-- 顶部面包屑/标题区域 -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="使用文档" FontSize="12" Opacity="0.6"/>
                        <TextBlock x:ConnectionId='4'                                                                                                            
                                 FontSize="24" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Markdown 内容 -->
                <TextBlock x:ConnectionId='3' 
                                                                      
                    TextWrapping="Wrap"
                    FontSize="14"
                    LineHeight="24"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
    
    <Page.Resources>
        <local:CategoryTitleConverter x:Key="CategoryTitleConverter"/>
    </Page.Resources>
</Page>

