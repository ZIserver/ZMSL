<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="ZMSL.App.Views.ServerDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        
                            >

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题栏 -->
        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="40,20" CornerRadius="0,0,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="20">
                    <Button x:ConnectionId='45'                    Padding="12,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                            <TextBlock Text="返回"/>
                        </StackPanel>
                    </Button>
                    <StackPanel>
                        <TextBlock x:ConnectionId='46' x:Name="ServerNameText" Text="服务器名称" FontSize="24" FontWeight="Bold"/>
                        <TextBlock x:ConnectionId='47' x:Name="ServerTypeText" Text="Paper 1.21.1" Opacity="0.7" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10">
                    <DropDownButton x:ConnectionId='33' x:Name="ServerOperationButton" Content="服务器操作" Style="{StaticResource AccentButtonStyle}" Padding="16,8">
                        <DropDownButton.Flyout>
                            <MenuFlyout Placement="BottomEdgeAlignedLeft">
                                <MenuFlyoutItem x:ConnectionId='41' x:Name="StartMenuItem" Text="启动"                    >
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE768;"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem x:ConnectionId='42' x:Name="RestartMenuItem" Text="重启"                       IsEnabled="False">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE72C;"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem x:ConnectionId='43' x:Name="StopMenuItem" Text="停止"                    IsEnabled="False">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE71A;"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem x:ConnectionId='44' x:Name="ForceStopMenuItem" Text="强制停止"                         IsEnabled="False">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE711;"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </DropDownButton.Flyout>
                    </DropDownButton>
                    <Button x:ConnectionId='34' x:Name="WhitelistButton" Content="白名单"                         Visibility="Collapsed" Padding="16,8"/>
                    <Button x:ConnectionId='35' x:Name="GameSettingsButton" Content="游戏设置"                            Visibility="Collapsed" Padding="16,8"/>
                    <Button x:ConnectionId='36' x:Name="PluginsButton" Content="插件管理"                       Visibility="Collapsed" Padding="16,8"/>
                    <Button x:ConnectionId='37' x:Name="ModsButton" Content="Mods管理"                    Visibility="Collapsed" Padding="16,8"/>
                    <Button x:ConnectionId='38' Content="备份管理"                            Padding="16,8"/>
                    <Button x:ConnectionId='39' Content="文件管理"                          Padding="16,8"/>
                    <Button x:ConnectionId='40' Content="服务器设置"                        Padding="16,8"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Row="1" Padding="40,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <!-- 控制台 -->
            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="12" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="控制台" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12"/>
                    <RichEditBox x:ConnectionId='27' x:Name="ConsoleOutput" 
                                 Grid.Row="1" 
                                 FontFamily="Consolas" 
                                 FontSize="12" 
                                 IsReadOnly="True" 
                                 TextWrapping="Wrap" 
                                 AcceptsReturn="True" 
                                 ScrollViewer.VerticalScrollBarVisibility="Auto" 
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                                                  >
                        <RichEditBox.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem x:ConnectionId='30' Text="复制"                          >
                                    <MenuFlyoutItem.Icon>
                                        <SymbolIcon Symbol="Copy"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem x:ConnectionId='31' Text="全选"                               >
                                    <MenuFlyoutItem.Icon>
                                        <SymbolIcon Symbol="SelectAll"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutSeparator/>
                                <MenuFlyoutItem x:ConnectionId='32' Text="AI 分析选中内容"                              >
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE9D9;"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </RichEditBox.ContextFlyout>
                    </RichEditBox>
                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBox x:ConnectionId='28' x:Name="CommandInput" 
                                 Grid.Column="0"
                                 PlaceholderText="输入命令..." 
                                                                
                                                                        
                                                                   />
                        
                        <Button x:ConnectionId='29' Grid.Column="1" Content="发送" Margin="8,0,0,0"                          />
                    </Grid>
                </Grid>
            </Border>

            <!-- 右侧面板 - 添加滚动视图 -->
            <ScrollViewer Grid.Column="1" Margin="20,0,0,0" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="16">
                <!-- 服务器概况 -->
                <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="服务器概况" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,16"/>
                        
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 服务器名称 -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="服务器名称" Opacity="0.7" FontSize="13"/>
                            <TextBlock x:ConnectionId='18' x:Name="OverviewServerName" Grid.Row="0" Grid.Column="1" Text="-" FontSize="13" TextAlignment="Right" TextWrapping="Wrap"/>

                            <!-- 游戏版本 -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="游戏版本" Opacity="0.7" FontSize="13"/>
                            <TextBlock x:ConnectionId='19' x:Name="OverviewGameVersion" Grid.Row="1" Grid.Column="1" Text="-" FontSize="13" TextAlignment="Right"/>

                            <!-- 服务端核心 -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="服务端核心" Opacity="0.7" FontSize="13"/>
                            <TextBlock x:ConnectionId='20' x:Name="OverviewCoreType" Grid.Row="2" Grid.Column="1" Text="-" FontSize="13" TextAlignment="Right"/>

                            <!-- 内存限制 -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="内存限制" Opacity="0.7" FontSize="13"/>
                            <TextBlock x:ConnectionId='21' x:Name="OverviewMemory" Grid.Row="3" Grid.Column="1" Text="-" FontSize="13" TextAlignment="Right"/>

                            <!-- 运行端口 -->
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="运行端口" Opacity="0.7" FontSize="13"/>
                            <TextBlock x:ConnectionId='22' x:Name="OverviewPort" Grid.Row="4" Grid.Column="1" Text="-" FontSize="13" TextAlignment="Right"/>

                            <!-- 正版验证 -->
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="正版验证" Opacity="0.7" FontSize="13"/>
                            <TextBlock x:ConnectionId='23' x:Name="OverviewOnlineMode" Grid.Row="5" Grid.Column="1" Text="-" FontSize="13" TextAlignment="Right"/>

                            <!-- 游戏模式 -->
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="游戏模式" Opacity="0.7" FontSize="13"/>
                            <TextBlock x:ConnectionId='24' x:Name="OverviewGameMode" Grid.Row="6" Grid.Column="1" Text="-" FontSize="13" TextAlignment="Right"/>

                            <!-- 游戏难度 -->
                            <TextBlock Grid.Row="7" Grid.Column="0" Text="游戏难度" Opacity="0.7" FontSize="13"/>
                            <TextBlock x:ConnectionId='25' x:Name="OverviewDifficulty" Grid.Row="7" Grid.Column="1" Text="-" FontSize="13" TextAlignment="Right"/>

                            <!-- 运行时长 -->
                            <TextBlock Grid.Row="8" Grid.Column="0" Text="运行时长" Opacity="0.7" FontSize="13"/>
                            <TextBlock x:ConnectionId='26' x:Name="OverviewUptime" Grid.Row="8" Grid.Column="1" Text="未运行" FontSize="13" TextAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 资源监控 -->
                <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="资源占用" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,16"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="CPU"/>
                            <ProgressBar x:ConnectionId='16' x:Name="CpuProgressBar" Grid.Column="1" Value="0" Maximum="100"/>
                            <TextBlock x:ConnectionId='17' x:Name="CpuText" Grid.Column="2" Text="0%" TextAlignment="Right"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="内存"/>
                            <ProgressBar x:ConnectionId='14' x:Name="MemoryProgressBar" Grid.Column="1" Value="0" Maximum="100"/>
                            <TextBlock x:ConnectionId='15' x:Name="MemoryText" Grid.Column="2" Text="0 MB" TextAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 玩家列表 -->
                <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <TextBlock Text="在线玩家" FontWeight="SemiBold" FontSize="16"/>
                            <TextBlock x:ConnectionId='13' x:Name="PlayerCountText" Text="0/20" HorizontalAlignment="Right" Opacity="0.7"/>
                        </Grid>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="250">
                            <ItemsControl x:ConnectionId='6' x:Name="PlayerListView">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="0,6" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding}" VerticalAlignment="Center" FontSize="14"/>
                                                <DropDownButton Grid.Column="1" Content="操作" FontSize="11" Padding="8,4">
                                                    <DropDownButton.Flyout>
                                                        <MenuFlyout Placement="BottomEdgeAlignedRight">
                                                            <MenuFlyoutItem x:ConnectionId='8' Text="踢出"                          Tag="{Binding}">
                                                                <MenuFlyoutItem.Icon>
                                                                    <FontIcon Glyph="&#xE711;"/>
                                                                </MenuFlyoutItem.Icon>
                                                            </MenuFlyoutItem>
                                                            <MenuFlyoutItem x:ConnectionId='9' Text="封禁"                         Tag="{Binding}">
                                                                <MenuFlyoutItem.Icon>
                                                                    <FontIcon Glyph="&#xE72E;"/>
                                                                </MenuFlyoutItem.Icon>
                                                            </MenuFlyoutItem>
                                                            <MenuFlyoutItem x:ConnectionId='10' Text="解除封禁"                            Tag="{Binding}">
                                                                <MenuFlyoutItem.Icon>
                                                                    <FontIcon Glyph="&#xE8FB;"/>
                                                                </MenuFlyoutItem.Icon>
                                                            </MenuFlyoutItem>
                                                            <MenuFlyoutSeparator/>
                                                            <MenuFlyoutItem x:ConnectionId='11' Text="给予管理"                      Tag="{Binding}">
                                                                <MenuFlyoutItem.Icon>
                                                                    <FontIcon Glyph="&#xE7EF;"/>
                                                                </MenuFlyoutItem.Icon>
                                                            </MenuFlyoutItem>
                                                            <MenuFlyoutItem x:ConnectionId='12' Text="撤回管理"                        Tag="{Binding}">
                                                                <MenuFlyoutItem.Icon>
                                                                    <FontIcon Glyph="&#xE7ED;"/>
                                                                </MenuFlyoutItem.Icon>
                                                            </MenuFlyoutItem>
                                                        </MenuFlyout>
                                                    </DropDownButton.Flyout>
                                                </DropDownButton>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <TextBlock x:ConnectionId='5' x:Name="NoPlayersText" Text="暂无在线玩家" Opacity="0.5" HorizontalAlignment="Center" Margin="0,8"/>
                    </StackPanel>
                </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
        
        <!-- 浮动命令建议 Popup - 放在根Grid下避免被裁剪 -->
        <Popup x:ConnectionId='2' x:Name="CommandSuggestionPopup" 
               Grid.RowSpan="2"
               IsLightDismissEnabled="False"
               IsOpen="False">
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Padding="4"
                    Width="500"
                    MaxHeight="300">
                <Border.Shadow>
                    <ThemeShadow />
                </Border.Shadow>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:ConnectionId='3' x:Name="SuggestionListView">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button x:ConnectionId='4' HorizontalAlignment="Stretch" 
                                        HorizontalContentAlignment="Left"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="12,8"
                                                                    
                                        Tag="{Binding}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Command}" FontWeight="SemiBold" FontSize="13"/>
                                        <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Popup>
    </Grid>
</Page>

