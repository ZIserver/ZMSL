<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="ZMSL.App.Views.AdvancedModePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        >

    <Grid Padding="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Border Background="{ThemeResource SystemFillColorAttentionBackgroundBrush}" 
                        CornerRadius="8" Width="40" Height="40" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xF168;" Foreground="{ThemeResource SystemFillColorAttentionBrush}" FontSize="20"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="高手模式" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="完全自定义配置" FontSize="12" Opacity="0.6"/>
                </StackPanel>
            </StackPanel>
            
            <!-- 步骤指示器 -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" 
                       Spacing="6" VerticalAlignment="Center">
                <Border Width="28" Height="3" Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="1.5"/>
                <Border Width="28" Height="3" Background="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="1.5"/>
                <Border Width="28" Height="3" Background="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="1.5"/>
            </StackPanel>
        </Grid>

        <!-- 配置内容 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel HorizontalAlignment="Stretch" Margin="40,20,40,20" Spacing="24">
                
                <!-- 基础配置 - 使用Grid平铺 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 左侧：服务器信息 -->
                    <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            CornerRadius="12" Padding="24" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1">
                        <StackPanel Spacing="20">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Border Background="{ThemeResource AccentFillColorDefaultBrush}" 
                                        Width="40" Height="40" CornerRadius="10">
                                    <FontIcon Glyph="&#xE70F;" FontSize="20" Foreground="White"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="服务器信息" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock Text="基础配置" FontSize="12" Opacity="0.6"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <StackPanel Spacing="12">
                                <TextBlock Text="服务器名称" FontSize="13" FontWeight="SemiBold" Opacity="0.8"/>
                                <TextBox x:ConnectionId='35' x:Name="ServerNameTextBox" PlaceholderText="输入服务器名称" 
                                         Text="我的服务器" FontSize="14" Height="40"/>
                            </StackPanel>
                            
                            <StackPanel Spacing="12">
                                <TextBlock Text="服务器端口" FontSize="13" FontWeight="SemiBold" Opacity="0.8"/>
                                <NumberBox x:ConnectionId='34' x:Name="PortNumberBox" Minimum="1" Maximum="65535" 
                                           Value="25565" SpinButtonPlacementMode="Compact" FontSize="14" Height="40"/>
                            </StackPanel>
                            
                            <CheckBox x:ConnectionId='33' x:Name="AutoAcceptEulaCheckBox" Content="自动接受 EULA 协议" 
                                      IsChecked="True" FontSize="13"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- 右侧：内存配置 -->
                    <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            CornerRadius="12" Padding="24" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1">
                        <StackPanel Spacing="20">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Border Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}" 
                                        Width="40" Height="40" CornerRadius="10">
                                    <FontIcon Glyph="&#xE950;" FontSize="20" Foreground="White"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="内存配置" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock Text="运行时资源" FontSize="12" Opacity="0.6"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <StackPanel Spacing="16">
                                <StackPanel Spacing="8">
                                    <Grid>
                                        <TextBlock Text="最小内存" FontSize="13" FontWeight="SemiBold" Opacity="0.8"/>
                                        <TextBlock x:ConnectionId='32' x:Name="MinMemoryValueText" Text="1024 MB" 
                                                   HorizontalAlignment="Right" FontSize="13" FontWeight="Bold" 
                                                   Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                    </Grid>
                                    <Slider x:ConnectionId='31' x:Name="MinMemorySlider" Minimum="512" Maximum="16384" 
                                            Value="1024" StepFrequency="512" 
                                                                                    />
                                </StackPanel>
                                
                                <StackPanel Spacing="8">
                                    <Grid>
                                        <TextBlock Text="最大内存" FontSize="13" FontWeight="SemiBold" Opacity="0.8"/>
                                        <TextBlock x:ConnectionId='30' x:Name="MaxMemoryValueText" Text="4096 MB" 
                                                   HorizontalAlignment="Right" FontSize="13" FontWeight="Bold" 
                                                   Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                    </Grid>
                                    <Slider x:ConnectionId='29' x:Name="MaxMemorySlider" Minimum="512" Maximum="16384" 
                                            Value="4096" StepFrequency="512" 
                                                                                    />
                                </StackPanel>
                            </StackPanel>
                            
                            <InfoBar x:ConnectionId='28' x:Name="MemoryWarningInfoBar" IsOpen="False" Severity="Warning" 
                                     Title="内存警告" IsClosable="False"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 核心选择 - 水平布局 -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                        CornerRadius="12" Padding="24" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                        BorderThickness="1">
                    <StackPanel Spacing="20">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}" 
                                    Width="40" Height="40" CornerRadius="10">
                                <FontIcon Glyph="&#xE8FD;" FontSize="20" Foreground="White"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="服务端核心" FontSize="18" FontWeight="Bold"/>
                                <TextBlock x:ConnectionId='27' x:Name="SummaryCoreText" Text="未选择核心" FontSize="12" Opacity="0.6"/>
                            </StackPanel>

                            <!-- Mode Switch -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,0,0,0" VerticalAlignment="Center">
                                <RadioButton x:ConnectionId='25' x:Name="OnlineModeRadio" Content="在线下载" IsChecked="True"                              GroupName="CoreSource"/>
                                <RadioButton x:ConnectionId='26' x:Name="LocalModeRadio" Content="本地导入"                              GroupName="CoreSource" Margin="12,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <Grid x:ConnectionId='12' x:Name="OnlineSelectionGrid">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="300"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- 核心分类 -->
                            <StackPanel Grid.Column="0" Spacing="8">
                                <TextBlock Text="核心分类" FontSize="13" FontWeight="SemiBold" Opacity="0.7" Margin="0,0,0,4"/>
                                <ScrollViewer MaxHeight="280" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:ConnectionId='23' x:Name="CoreCategoriesPanel">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button x:ConnectionId='24'                        Tag="{Binding Name}" 
                                                        HorizontalAlignment="Stretch" Padding="12,10" Margin="0,0,0,6"
                                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                        BorderThickness="1" CornerRadius="8">
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="13"/>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                            
                            <!-- 核心列表 -->
                            <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" 
                                    CornerRadius="8" Padding="16" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                                    BorderThickness="1">
                                <StackPanel Spacing="8">
                                    <TextBlock x:ConnectionId='20' x:Name="SelectedCategoryText" Text="选择分类查看核心" 
                                               FontSize="13" FontWeight="SemiBold" Opacity="0.7"/>
                                    <ScrollViewer MaxHeight="240" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl x:ConnectionId='21' x:Name="CoreListView">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button x:ConnectionId='22'                    Tag="{Binding}" 
                                                            HorizontalAlignment="Stretch" Padding="12,10" Margin="0,0,0,6"
                                                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                            BorderThickness="1" CornerRadius="6">
                                                        <TextBlock Text="{Binding}" FontSize="13"/>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>
                            
                            <!-- 版本列表 -->
                            <Border x:ConnectionId='17' x:Name="VersionSelectionBorder" Grid.Column="4"
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" 
                                    CornerRadius="8" Padding="16" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                                    BorderThickness="1" Visibility="Collapsed">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="可用版本" FontSize="13" FontWeight="SemiBold" Opacity="0.7"/>
                                    <ScrollViewer MaxHeight="240" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl x:ConnectionId='18' x:Name="VersionListView">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button x:ConnectionId='19'                       Tag="{Binding}" 
                                                            HorizontalAlignment="Stretch" Padding="12,10" Margin="0,0,0,6"
                                                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                            BorderThickness="1" CornerRadius="6">
                                                        <TextBlock Text="{Binding}" FontSize="13"/>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Local Import Panel -->
                        <StackPanel x:ConnectionId='13' x:Name="LocalImportPanel" Visibility="Collapsed" Spacing="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Spacing="10">
                                    <TextBlock Text="服务端核心文件 (.jar)" FontSize="13" FontWeight="SemiBold" Opacity="0.8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:ConnectionId='15' x:Name="LocalCorePathTextBox" PlaceholderText="请选择本地核心文件" IsReadOnly="True" Margin="0,0,12,0"/>
                                        <Button x:ConnectionId='16' Grid.Column="1" Content="浏览"                              />
                                    </Grid>
                                    <TextBlock Text="请确保您选择的是有效的 Minecraft 服务端核心文件" FontSize="12" Opacity="0.5"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="2" Spacing="10">
                                    <TextBlock Text="Minecraft 版本" FontSize="13" FontWeight="SemiBold" Opacity="0.8"/>
                                    <TextBox x:ConnectionId='14' x:Name="LocalCoreVersionTextBox" PlaceholderText="例如: 1.20.1"                                           />
                                    <TextBlock Text="请手动输入该核心对应的 Minecraft 版本" FontSize="12" Opacity="0.5"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Java和JVM配置 - 平铺 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Java信息 -->
                    <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            CornerRadius="12" Padding="24" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1">
                        <StackPanel Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Border Background="{ThemeResource SystemFillColorAttentionBackgroundBrush}" 
                                        Width="40" Height="40" CornerRadius="10">
                                    <FontIcon Glyph="&#xE943;" FontSize="20" Foreground="White"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Java 运行时" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock Text="已检测到的版本" FontSize="12" Opacity="0.6"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <ComboBox x:ConnectionId='9' x:Name="JavaVersionComboBox" HorizontalAlignment="Stretch" 
                                      PlaceholderText="正在检测..."                                                        >
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayText}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Path}" FontSize="11" Opacity="0.6" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            
                            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" 
                                    CornerRadius="8" Padding="12">
                                <TextBlock x:ConnectionId='10' x:Name="JavaInfoText" Text="检测中..." 
                                           FontSize="12" TextWrapping="Wrap" Opacity="0.7"/>
                            </Border>
                        </StackPanel>
                    </Border>
                    
                    <!-- JVM参数 -->
                    <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            CornerRadius="12" Padding="24" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1">
                        <StackPanel Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Border Background="{ThemeResource SystemFillColorCautionBackgroundBrush}" 
                                        Width="40" Height="40" CornerRadius="10">
                                    <FontIcon Glyph="&#xE945;" FontSize="20" Foreground="White"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="JVM 参数" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock Text="高级配置" FontSize="12" Opacity="0.6"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <TextBox x:ConnectionId='8' x:Name="JvmArgsTextBox" PlaceholderText="-XX:+UseG1GC -XX:+UnlockExperimentalVMOptions" 
                                     TextWrapping="Wrap" AcceptsReturn="True" Height="100" 
                                     ScrollViewer.VerticalScrollBarVisibility="Auto" FontSize="13"/>
                            <TextBlock Text="每行一个参数，无需添加 -Xmx 和 -Xms" FontSize="11" Opacity="0.5"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 配置摘要 -->
                <Border Background="{ThemeResource AccentFillColorDefaultBrush}" 
                        CornerRadius="12" Padding="24" Opacity="0.95">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Background="White" Width="48" Height="48" CornerRadius="12" Opacity="0.15"/>
                        <FontIcon Glyph="&#xE73E;" FontSize="24" Foreground="White" 
                                  HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        
                        <StackPanel Grid.Column="1" Margin="20,0,0,0" Spacing="8">
                            <TextBlock Text="配置摘要" FontSize="16" FontWeight="Bold" Foreground="White"/>
                            <StackPanel Orientation="Horizontal" Spacing="24">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE8FD;" FontSize="12" Foreground="White" Opacity="0.8"/>
                                    <TextBlock x:ConnectionId='7' x:Name="SummaryCoreText2" Text="核心: 未选择" FontSize="13" Foreground="White" Opacity="0.9"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE950;" FontSize="12" Foreground="White" Opacity="0.8"/>
                                    <TextBlock x:ConnectionId='6' x:Name="SummaryMemoryText" Text="内存: 1-4 GB" FontSize="13" Foreground="White" Opacity="0.9"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE8DE;" FontSize="12" Foreground="White" Opacity="0.8"/>
                                    <TextBlock x:ConnectionId='5' x:Name="SummaryPortText" Text="端口: 25565" FontSize="13" Foreground="White" Opacity="0.9"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- 底部按钮栏 -->
        <Grid Grid.Row="2" Margin="0,24,0,0" 
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
              BorderThickness="0,1,0,0" Padding="16">
            <Grid HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:ConnectionId='3'                          Padding="16,10">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                            <TextBlock Text="返回" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button x:ConnectionId='4'                            Padding="16,10">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE711;" FontSize="14"/>
                            <TextBlock Text="取消" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                
                <Button x:ConnectionId='2' x:Name="NextButton" Grid.Column="1"
                                                 
                        Style="{StaticResource AccentButtonStyle}" 
                        Padding="24,10" MinWidth="120">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="下一步" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <FontIcon Glyph="&#xE72A;" FontSize="14"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</Page>

