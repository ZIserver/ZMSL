<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ZMSL.App.Views.ForumCreatePostPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:dto="using:ZMSL.Shared.DTOs"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Padding="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,32">
            <TextBlock Text="发布新帖" FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="分享你的见解 (支持 Markdown)" FontSize="14" Opacity="0.6"/>
        </StackPanel>

        <!-- 表单 -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="24" MaxWidth="800" HorizontalAlignment="Center">
                
                <TextBox Header="标题" PlaceholderText="请输入帖子标题" 
                         Text="{Binding Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         MaxLength="100"/>

                <ComboBox Header="版块" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                          HorizontalAlignment="Stretch" DisplayMemberPath="Name"/>

                <!-- 双栏 Markdown 编辑器 -->
                <Grid Height="600" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 工具栏 -->
                    <Border Grid.Row="0" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}">
                        <StackPanel Orientation="Horizontal" Padding="8,4" Spacing="4">
                            <Button x:ConnectionId='11' ToolTipService.ToolTip="加粗 (Ctrl+B)"                              Tag="Bold" Background="Transparent" BorderThickness="0" Padding="8,4">
                                <TextBlock Text="B" FontFamily="Times New Roman" FontWeight="Bold" FontSize="18"/>
                            </Button>
                            <Button x:ConnectionId='12' ToolTipService.ToolTip="斜体 (Ctrl+I)"                              Tag="Italic" Background="Transparent" BorderThickness="0" Padding="8,4">
                                <TextBlock Text="I" FontFamily="Times New Roman" FontStyle="Italic" FontSize="18"/>
                            </Button>
                            <Button x:ConnectionId='13' ToolTipService.ToolTip="删除线"                              Tag="Strikethrough" Background="Transparent" BorderThickness="0" Padding="8,4">
                                <FontIcon Glyph="&#xEDE0;" FontSize="16"/>
                            </Button>
                            
                            <AppBarSeparator/>
                            
                            <Button x:ConnectionId='14' Content="H1" FontWeight="SemiBold" ToolTipService.ToolTip="标题 1"                              Tag="H1" Background="Transparent" BorderThickness="0" Padding="8,4"/>
                            <Button x:ConnectionId='15' Content="H2" FontWeight="SemiBold" ToolTipService.ToolTip="标题 2"                              Tag="H2" Background="Transparent" BorderThickness="0" Padding="8,4"/>
                            <Button x:ConnectionId='16' Content="H3" FontWeight="SemiBold" ToolTipService.ToolTip="标题 3"                              Tag="H3" Background="Transparent" BorderThickness="0" Padding="8,4"/>
                            <Button x:ConnectionId='17' Content="H4" FontWeight="SemiBold" ToolTipService.ToolTip="标题 4"                              Tag="H4" Background="Transparent" BorderThickness="0" Padding="8,4"/>
                            <Button x:ConnectionId='18' Content="H5" FontWeight="SemiBold" ToolTipService.ToolTip="标题 5"                              Tag="H5" Background="Transparent" BorderThickness="0" Padding="8,4"/>
                            <Button x:ConnectionId='19' Content="H6" FontWeight="SemiBold" ToolTipService.ToolTip="标题 6"                              Tag="H6" Background="Transparent" BorderThickness="0" Padding="8,4"/>
                            
                            <AppBarSeparator/>
                            
                            <Button x:ConnectionId='20' ToolTipService.ToolTip="引用"                              Tag="Quote" Background="Transparent" BorderThickness="0" Padding="8,4">
                                <FontIcon Glyph="&#xE9B1;" FontSize="16"/>
                            </Button>
                            <Button x:ConnectionId='21' ToolTipService.ToolTip="代码块"                              Tag="CodeBlock" Background="Transparent" BorderThickness="0" Padding="8,4">
                                <FontIcon Glyph="&#xE943;" FontSize="16"/>
                            </Button>
                            <Button x:ConnectionId='22' ToolTipService.ToolTip="插入链接"                              Tag="Link" Background="Transparent" BorderThickness="0" Padding="8,4">
                                <FontIcon Glyph="&#xE71B;" FontSize="16"/>
                            </Button>
                            <Button x:ConnectionId='23' ToolTipService.ToolTip="插入图片"                              Tag="Image" Background="Transparent" BorderThickness="0" Padding="8,4">
                                <FontIcon Glyph="&#xEB9F;" FontSize="16"/>
                            </Button>
                            
                            <AppBarSeparator/>
                            
                            <Button x:ConnectionId='24' ToolTipService.ToolTip="无序列表"                              Tag="List" Background="Transparent" BorderThickness="0" Padding="8,4">
                                <FontIcon Glyph="&#xE8FD;" FontSize="16"/>
                            </Button>
                            <Button x:ConnectionId='25' ToolTipService.ToolTip="插入表格"                              Tag="Table" Background="Transparent" BorderThickness="0" Padding="8,4">
                                <FontIcon Glyph="&#xE8D1;" FontSize="16"/>
                            </Button>
                            
                            <AppBarSeparator/>
                            
                            <ToggleButton x:ConnectionId='26' x:Name="PreviewToggle" Content="分屏预览" IsChecked="True"                             ToolTipService.ToolTip="显示/隐藏预览" Background="Transparent" BorderThickness="0" Padding="8,4">
                            </ToggleButton>
                        </StackPanel>
                    </Border>

                    <!-- 编辑区与预览区 -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:ConnectionId='5' Width="*" x:Name="EditorColumn"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition x:ConnectionId='6' Width="*" x:Name="PreviewColumn"/>
                        </Grid.ColumnDefinitions>

                        <!-- 编辑区 -->
                        <TextBox x:ConnectionId='7' x:Name="EditorBox" 
                                 Grid.Column="0"
                                 AcceptsReturn="True" 
                                 TextWrapping="Wrap" 
                                 ScrollViewer.VerticalScrollBarVisibility="Visible"
                                 BorderThickness="0"
                                 Padding="12"
                                 FontFamily="Consolas"
                                 FontSize="14"
                                 PlaceholderText="在此输入 Markdown 内容..."
                                 Text="{Binding Content, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                    
                                                            
                                                          />

                        <!-- 分割线 -->
                        <Border Grid.Column="1" Width="1" Background="{ThemeResource SurfaceStrokeColorDefaultBrush}"/>

                        <!-- 预览区 -->
                        <ScrollViewer x:ConnectionId='8' x:Name="PreviewScrollViewer" Grid.Column="2" Padding="12" Background="{ThemeResource LayerFillColorDefaultBrush}">
                            <StackPanel x:ConnectionId='9' x:Name="PreviewContainer">
                                <TextBlock x:ConnectionId='10' x:Name="PreviewErrorText" 
                                           Foreground="Red" 
                                           Visibility="Collapsed" 
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- 状态栏 -->
                    <Grid Grid.Row="2" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderThickness="0,1,0,0" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" Padding="12,4">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="16">
                            <TextBlock x:ConnectionId='4' x:Name="WordCountText" Text="0 字符" FontSize="12" Opacity="0.6"/>
                        </StackPanel>
                    </Grid>
                </Grid>
                
                <TextBlock Text="{Binding StatusMessage}" Foreground="Red" FontSize="14"/>
            </StackPanel>
        </ScrollViewer>

        <!-- 按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="16" Margin="0,24,0,0" HorizontalAlignment="Center">
            <Button x:ConnectionId='2' Content="发布"                            Style="{StaticResource AccentButtonStyle}" Width="120"/>
            <Button x:ConnectionId='3' Content="取消"                            Width="100"/>
        </StackPanel>

        <!-- 加载遮罩 -->
        <Grid Grid.RowSpan="3" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Opacity="0.8"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <ProgressRing Width="64" Height="64" IsActive="True"/>
        </Grid>
    </Grid>
</Page>

