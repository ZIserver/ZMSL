<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="ZMSL.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        >

    <ScrollViewer Padding="40,32">
        <StackPanel Spacing="20">
            <TextBlock Text="设置" FontSize="32" FontWeight="Bold" Margin="0,0,0,8"/>

            <!-- 第一行: Java设置 + 存储设置 -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Java设置 -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="24">
                    <StackPanel Spacing="20">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE7F8;" FontSize="20" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="Java 配置" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>
                        
                        <StackPanel>
                            <TextBlock Text="检测到的Java路径" Opacity="0.7" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:ConnectionId='37' x:Name="DetectedJavaText" Text="未检测到" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <Button x:ConnectionId='38' Grid.Column="1" Content="使用" x:Name="UseDetectedButton"                               Margin="8,0,0,0" Padding="12,6"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="自定义Java路径" Opacity="0.7" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:ConnectionId='35' x:Name="JavaPathBox" PlaceholderText="留空使用系统默认Java"/>
                                <Button x:ConnectionId='36' Grid.Column="1" Content="浏览" Margin="8,0,0,0"                          Padding="12,6"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 存储设置 -->
                <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="24">
                    <StackPanel Spacing="20">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE8B7;" FontSize="20" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="存储设置" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>
                        
                        <StackPanel>
                            <TextBlock Text="服务器默认存储路径" Opacity="0.7" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:ConnectionId='33' x:Name="ServerPathBox"/>
                                <Button x:ConnectionId='34' Grid.Column="1" Content="浏览" Margin="8,0,0,0"                                Padding="12,6"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 第二行: 备份设置 + 关于 -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 备份设置 -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="24">
                    <StackPanel Spacing="20">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE896;" FontSize="20" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="备份设置" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>
                        
                        <ToggleSwitch x:ConnectionId='28' x:Name="EnableAutoBackupToggle" Header="启用自动备份"                                         />
                        
                        <StackPanel>
                            <TextBlock Text="备份间隔" Opacity="0.7" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel>
                                    <TextBlock Text="小时" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                                    <NumberBox x:ConnectionId='32' x:Name="BackupIntervalHoursBox" 
                                               Minimum="0" 
                                               SpinButtonPlacementMode="Inline"
                                                                                                 />
                                </StackPanel>
                                
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="分钟" FontSize="12" Opacity="0.6" Margin="0,0,0,4"/>
                                    <NumberBox x:ConnectionId='31' x:Name="BackupIntervalMinutesBox" 
                                               Minimum="0" 
                                               Maximum="59" 
                                               SpinButtonPlacementMode="Inline"
                                                                                                   />
                                </StackPanel>
                            </Grid>
                            <TextBlock x:ConnectionId='30' x:Name="BackupIntervalHintText" 
                                       Text="" 
                                       FontSize="12" 
                                       Opacity="0.6" 
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                        
                        <StackPanel>
                            <TextBlock Text="保留备份数量" Opacity="0.7" Margin="0,0,0,6"/>
                            <NumberBox x:ConnectionId='29' x:Name="BackupRetentionBox" Minimum="1" Maximum="99" Value="7" SpinButtonPlacementMode="Inline"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 关于 -->
                <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="24">
                    <StackPanel Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE946;" FontSize="20" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="关于" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>
                        
                        <StackPanel Spacing="8">
                            <TextBlock Text="ZMSL 我的世界服务器启动器" FontSize="16" FontWeight="SemiBold"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock x:ConnectionId='26' x:Name="VersionText" Text="版本 1.0.0" Opacity="0.7"/>
                                <Button x:ConnectionId='27' x:Name="CheckUpdateButton" Content="检查更新"                           Padding="12,6" VerticalAlignment="Center"/>
                            </StackPanel>
                            <ToggleSwitch x:ConnectionId='23' x:Name="AutoCheckUpdateToggle" Header="启动时自动检查更新"                                        />
                            <StackPanel x:ConnectionId='24' x:Name="PendingUpdatePanel" Visibility="Collapsed" Spacing="6">
                                <TextBlock Text="已有新版本下载完成，重启后将自动安装" Foreground="{ThemeResource SystemAccentColor}" FontSize="13"/>
                                <Button x:ConnectionId='25' x:Name="RestartAndUpdateButton" Content="立即重启并更新" Style="{StaticResource AccentButtonStyle}"                                HorizontalAlignment="Left" Padding="12,8"/>
                            </StackPanel>
                            <TextBlock Text="基于 WinUI 3 开发" Opacity="0.5" FontSize="12"/>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="功能特性" FontSize="14" FontWeight="SemiBold" Opacity="0.8"/>
                            <TextBlock Text="• 支持 Paper/Purpur/Vanilla/Forge 等核心" FontSize="12" Opacity="0.7"/>
                            <TextBlock Text="• 自动备份服务器数据" FontSize="12" Opacity="0.7"/>
                            <TextBlock Text="• 支持 Linux/Windows 远程节点管理" FontSize="12" Opacity="0.7"/>
                            <TextBlock Text="• 内置 FRP 内网穿透支持" FontSize="12" Opacity="0.7"/>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="开发者" FontSize="14" FontWeight="SemiBold" Opacity="0.8"/>
                            <TextBlock Text="© 2026 智穗科技" FontSize="12" Opacity="0.7"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 第三行: 外观设置 + 下载/控制台设置 -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 外观设置 -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="24">
                    <StackPanel Spacing="20">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE790;" FontSize="20" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="外观设置" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>
                        
                        <ToggleSwitch x:ConnectionId='18' x:Name="EnableMicaEffectToggle" Header="启用窗口云母/毛玻璃效果"                                         />
                        <StackPanel>
                            <TextBlock Text="云母效果强度" Opacity="0.7" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:ConnectionId='22' x:Name="MicaIntensitySlider" Minimum="0" Maximum="2" StepFrequency="1"                                                 VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=MicaIntensitySlider}" VerticalAlignment="Center" Margin="12,0,0,0" MinWidth="20"/>
                            </Grid>
                        </StackPanel>
                        <ToggleSwitch x:ConnectionId='19' x:Name="UseCustomBackgroundToggle" Header="使用自定义背景图"                                            />
                        <StackPanel>
                            <TextBlock Text="背景图片路径" Opacity="0.7" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:ConnectionId='20' x:Name="BackgroundImagePathBox" IsReadOnly="True" PlaceholderText="未选择图片"/>
                                <Button x:ConnectionId='21' Grid.Column="1" Content="选择图片" Margin="8,0,0,0"                                     Padding="12,6"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 下载与控制台设置 -->
                <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="24">
                    <StackPanel Spacing="20">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE896;" FontSize="20" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                            <TextBlock Text="下载与控制台" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>

                        <!-- 下载设置 -->
                        <StackPanel Spacing="12">
                            <TextBlock Text="下载设置" FontSize="14" FontWeight="SemiBold" Opacity="0.8"/>
                            
                            <StackPanel>
                                <TextBlock Text="下载镜像源" Opacity="0.7" Margin="0,0,0,6"/>
                                <ComboBox x:ConnectionId='16' x:Name="MirrorSourceCombo"                                                       HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="MSL 官方源" Tag="MSL"/>
                                    <ComboBoxItem Content="ZSync 镜像源" Tag="ZSync"/>
                                </ComboBox>
                                <TextBlock x:ConnectionId='17' x:Name="MirrorSourceHintText" Text="" FontSize="12" Opacity="0.6" Margin="0,4,0,0"/>
                            </StackPanel>
                            
                            <ToggleSwitch x:ConnectionId='13' x:Name="ForceMultiThreadToggle" Header="强制多线程下载"                                         />
                            
                            <StackPanel>
                                <TextBlock Text="下载线程数" Opacity="0.7" Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider x:ConnectionId='14' x:Name="DownloadThreadsSlider" Minimum="1" Maximum="32" StepFrequency="1"                                                   VerticalAlignment="Center"/>
                                    <TextBlock x:ConnectionId='15' Grid.Column="1" x:Name="DownloadThreadsValueText" Text="{Binding Value, ElementName=DownloadThreadsSlider}" VerticalAlignment="Center" Margin="12,0,0,0" MinWidth="20"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>

                        <MenuFlyoutSeparator/>

                        <!-- 控制台设置 -->
                        <StackPanel Spacing="12">
                            <TextBlock Text="控制台设置" FontSize="14" FontWeight="SemiBold" Opacity="0.8"/>
                            <StackPanel>
                                <TextBlock Text="控制台编码" Opacity="0.7" Margin="0,0,0,6"/>
                                <ComboBox x:ConnectionId='12' x:Name="ConsoleEncodingCombo"                                                          HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="UTF-8" Tag="UTF-8"/>
                                    <ComboBoxItem Content="ANSI (系统默认)" Tag="ANSI"/>
                                    <ComboBoxItem Content="GB18030" Tag="GB18030"/>
                                </ComboBox>
                            </StackPanel>
                            
                            <StackPanel>
                                <TextBlock Text="控制台字体大小" Opacity="0.7" Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider x:ConnectionId='11' x:Name="ConsoleFontSizeSlider" Minimum="8" Maximum="24" StepFrequency="1"                                                   VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Value, ElementName=ConsoleFontSizeSlider}" VerticalAlignment="Center" Margin="12,0,0,0" MinWidth="20"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 第四行: 常规与启动 -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="24">
                <StackPanel Spacing="20">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="&#xE770;" FontSize="20" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <TextBlock Text="常规与启动" FontSize="18" FontWeight="SemiBold"/>
                    </StackPanel>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Spacing="12">
                            <ToggleSwitch x:ConnectionId='9' x:Name="StartOnBootToggle" Header="开机自启动"                                    />
                            <ToggleSwitch x:ConnectionId='10' x:Name="AutoStartLastServerToggle" Header="启动时自动运行上次服务器"                                            />
                        </StackPanel>
                        
                        <StackPanel Grid.Column="2" Spacing="12">
                            <ToggleSwitch x:ConnectionId='7' x:Name="AutoRestartAppOnCrashToggle" Header="软件崩溃自动重启"                                              />
                            <ToggleSwitch x:ConnectionId='8' x:Name="AutoRestartServerOnCrashToggle" Header="服务器崩溃自动重启"                                                 />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 第五行: 鸣谢 -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="24">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="&#xE8BD;" FontSize="20" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <TextBlock Text="鸣谢" FontSize="18" FontWeight="SemiBold"/>
                    </StackPanel>
                    
                    <TextBlock Text="感谢以下项目和组织对本软件的支持" Opacity="0.7" FontSize="13"/>
                    
                    <ProgressRing x:ConnectionId='4' x:Name="AcknowledgmentsLoadingRing" IsActive="True" Width="24" Height="24" HorizontalAlignment="Left"/>
                    
                    <StackPanel x:ConnectionId='5' x:Name="AcknowledgmentsPanel" Orientation="Horizontal" Spacing="12"/>
                    
                    <TextBlock x:ConnectionId='6' x:Name="NoAcknowledgmentsText" 
                               Text="暂无鸣谢信息" 
                               Opacity="0.5" 
                               FontSize="13"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <!-- 保存按钮区域 -->
            <StackPanel HorizontalAlignment="Center" Spacing="12" Margin="0,20,0,40">
                <Button x:ConnectionId='2' Style="{StaticResource AccentButtonStyle}" 
                        Content="保存设置" 
                                           
                        MinWidth="200"
                        Padding="24,12"
                        FontSize="16"/>
                <TextBlock x:ConnectionId='3' x:Name="StatusText" 
                           Text="" 
                           HorizontalAlignment="Center" 
                           Opacity="0.7"
                           FontSize="14"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>

