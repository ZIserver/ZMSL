<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="ZMSL.App.Views.DataAnalysisPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ZMSL.App.Views"
    xmlns:viewmodels="using:ZMSL.App.ViewModels"
                        >

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 页面标题和控制栏 -->
        <StackPanel Grid.Row="0" Spacing="16">
            <TextBlock Text="数据分析面板" 
                       FontSize="24" 
                       FontWeight="Bold"/>
            
            <!-- 控制面板 -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" 
                    Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="筛选条件" 
                               FontSize="16" 
                               FontWeight="SemiBold"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <ComboBox x:ConnectionId='35' x:Name="ServerSelector"
                                  Grid.Column="0"
                                  Header="选择服务器"
                                  PlaceholderText="请选择服务器"
                                  Margin="0,0,12,0"/>
                        
                        <DatePicker x:ConnectionId='36' x:Name="StartDatePicker"
                                    Grid.Column="1"
                                    Header="开始日期"
                                    Margin="0,0,12,0"/>
                        
                        <DatePicker x:ConnectionId='37' x:Name="EndDatePicker"
                                    Grid.Column="2"
                                    Header="结束日期"
                                    Margin="0,0,12,0"/>
                        
                        <StackPanel Grid.Column="3" 
                                    Orientation="Horizontal" 
                                    Spacing="8">
                            <Button x:ConnectionId='38' Content="加载数据" 
                                                                                        
                                    Style="{StaticResource AccentButtonStyle}"/>
                            <Button x:ConnectionId='39' Content="重置" 
                                                                                    />
                        </StackPanel>
                    </Grid>
                    
                    <TextBlock x:ConnectionId='34'                                                     
                               FontSize="12"
                               Opacity="0.7"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- 主要内容区域 -->
        <ScrollViewer Grid.Row="2" Margin="0,16,0,0">
            <StackPanel Spacing="20">
                
                <!-- 性能统计卡片 -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" 
                        Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="性能统计" 
                                   FontSize="18" 
                                   FontWeight="SemiBold"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- CPU统计 -->
                            <StackPanel Grid.Column="0" Spacing="8">
                                <TextBlock Text="CPU使用率" 
                                           FontSize="14" 
                                           Opacity="0.8"/>
                                <TextBlock x:ConnectionId='31'                                                                                                    
                                           FontSize="24" 
                                           FontWeight="Bold"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="最高:" FontSize="12" Opacity="0.7"/>
                                    <TextBlock x:ConnectionId='33'                                                                                                 
                                               FontSize="12"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="最低:" FontSize="12" Opacity="0.7"/>
                                    <TextBlock x:ConnectionId='32'                                                                                                 
                                               FontSize="12"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <!-- 内存统计 -->
                            <StackPanel Grid.Column="1" Spacing="8">
                                <TextBlock Text="内存使用率" 
                                           FontSize="14" 
                                           Opacity="0.8"/>
                                <TextBlock x:ConnectionId='28'                                                                                                       
                                           FontSize="24" 
                                           FontWeight="Bold"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="最高:" FontSize="12" Opacity="0.7"/>
                                    <TextBlock x:ConnectionId='30'                                                                                                    
                                               FontSize="12"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="最低:" FontSize="12" Opacity="0.7"/>
                                    <TextBlock x:ConnectionId='29'                                                                                                    
                                               FontSize="12"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <!-- 玩家统计 -->
                            <StackPanel Grid.Column="2" Spacing="8">
                                <TextBlock Text="玩家统计" 
                                           FontSize="14" 
                                           Opacity="0.8"/>
                                <TextBlock x:ConnectionId='25'                                                    
                                           FontSize="24" 
                                           FontWeight="Bold"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="活跃:" FontSize="12" Opacity="0.7"/>
                                    <TextBlock x:ConnectionId='27'                                                      
                                               FontSize="12"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="新增:" FontSize="12" Opacity="0.7"/>
                                    <TextBlock x:ConnectionId='26'                                                   
                                               FontSize="12"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <!-- 平均游戏时间 -->
                            <StackPanel Grid.Column="3" Spacing="8">
                                <TextBlock Text="平均游戏时间" 
                                           FontSize="14" 
                                           Opacity="0.8"/>
                                <TextBlock x:ConnectionId='23'                                                                                                         
                                           FontSize="24" 
                                           FontWeight="Bold"/>
                                <TextBlock Text="分钟" 
                                           FontSize="12" 
                                           Opacity="0.7"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="峰值:" FontSize="12" Opacity="0.7"/>
                                    <TextBlock x:ConnectionId='24'                                                          
                                               FontSize="12"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 图表区域 -->
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- CPU使用率分布图 -->
                    <Border Grid.Column="0" 
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" 
                            Padding="16">
                        <StackPanel Spacing="12">
                            <TextBlock Text="CPU使用率分布" 
                                       FontSize="16" 
                                       FontWeight="SemiBold"/>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                                <TextBlock x:ConnectionId='22'                                                                                                         
                                           FontSize="48"
                                           FontWeight="Bold"/>
                                <TextBlock Text="CPU使用率"
                                           FontSize="14"
                                           Opacity="0.7"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <!-- 内存使用率分布图 -->
                    <Border Grid.Column="1" 
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" 
                            Padding="16">
                        <StackPanel Spacing="12">
                            <TextBlock Text="内存使用率分布" 
                                       FontSize="16" 
                                       FontWeight="SemiBold"/>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                                <TextBlock x:ConnectionId='21'                                                                                                            
                                           FontSize="48"
                                           FontWeight="Bold"/>
                                <TextBlock Text="内存使用率"
                                           FontSize="14"
                                           Opacity="0.7"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 资源消耗和建议 -->
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 资源消耗统计 -->
                    <Border Grid.Column="0" 
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" 
                            Padding="16">
                        <StackPanel Spacing="12">
                            <TextBlock Text="资源消耗统计" 
                                       FontSize="16" 
                                       FontWeight="SemiBold"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                    <TextBlock Text="CPU平均使用" FontSize="14" Opacity="0.8"/>
                                    <TextBlock x:ConnectionId='20'                                                                                                          
                                               FontSize="20" FontWeight="Bold"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                    <TextBlock Text="CPU峰值使用" FontSize="14" Opacity="0.8"/>
                                    <TextBlock x:ConnectionId='19'                                                                                                       
                                               FontSize="20" FontWeight="Bold"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4" Margin="0,12,0,0">
                                    <TextBlock Text="内存平均使用" FontSize="14" Opacity="0.8"/>
                                    <TextBlock x:ConnectionId='18'                                                                                                             
                                               FontSize="20" FontWeight="Bold"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4" Margin="0,12,0,0">
                                    <TextBlock Text="内存峰值使用" FontSize="14" Opacity="0.8"/>
                                    <TextBlock x:ConnectionId='17'                                                                                                          
                                               FontSize="20" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                    
                    <!-- 优化建议 -->
                    <Border Grid.Column="1" 
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" 
                            Padding="16">
                        <StackPanel Spacing="12">
                            <TextBlock Text="优化建议" 
                                       FontSize="16" 
                                       FontWeight="SemiBold"/>
                            
                            <ItemsControl x:ConnectionId='12'                                                              >
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate                      >
                                        <Border x:ConnectionId='15' Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                CornerRadius="4" 
                                                Padding="12" 
                                                Margin="0,0,0,8">
                                            <TextBlock x:ConnectionId='16'                 
                                                       TextWrapping="Wrap" 
                                                       FontSize="13"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            
                            <TextBlock x:ConnectionId='13' Text="暂无建议" 
                                       FontSize="14" 
                                       Opacity="0.5"
                                       HorizontalAlignment="Center"
                                                                                                                                                   />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 自定义报表 -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" 
                        Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="自定义报表" 
                                   FontSize="18" 
                                   FontWeight="SemiBold"/>
                        
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button x:ConnectionId='10' Content="生成报表" 
                                                                                            
                                    Style="{StaticResource AccentButtonStyle}"/>
                            <Button x:ConnectionId='11' Content="导出数据" 
                                                                                  />
                        </StackPanel>
                        
                        <ItemsControl x:ConnectionId='2'                                                                  >
                            <ItemsControl.ItemTemplate>
                                <DataTemplate                                            >
                                    <Border x:ConnectionId='4' Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            CornerRadius="8" 
                                            Padding="16" 
                                            Margin="0,0,0,12">
                                        <StackPanel Spacing="8">
                                            <TextBlock x:ConnectionId='5'                      
                                                       FontSize="16" 
                                                       FontWeight="SemiBold"/>
                                            <ItemsControl x:ConnectionId='6'                              >
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="16"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate                      >
                                                        <Border x:ConnectionId='8' Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                                CornerRadius="4" 
                                                                Padding="8,4">
                                                            <TextBlock x:ConnectionId='9'                                                                  
                                                                       Foreground="White" 
                                                                       FontWeight="SemiBold"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

