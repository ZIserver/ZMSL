<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="ZMSL.App.Views.LotteryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ZMSL.App.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:ZMSL.App.Models"
    xmlns:converters="using:ZMSL.App.Converters"
    mc:Ignorable="d"
                        >

    <Page.Resources>
        <converters:LotteryStatusColorConverter x:Key="LotteryStatusColorConverter"/>
        <converters:BoolToVisibilityConverter x:Key="VisibleIfTrue"/>
        <converters:BoolToVisibilityConverter x:Key="VisibleIfFalse" Invert="True"/>
        <converters:StringToImageSourceConverter x:Key="StringToImageSourceConverter"/>
        <converters:DateTimeToStringConverter x:Key="DateTimeToStringConverter"/>
        <converters:StringFormatConverter x:Key="StringFormatConverter"/>
    </Page.Resources>

    <Grid Padding="36">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Grid Grid.Row="0" Margin="0,0,0,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Spacing="8">
                <TextBlock Text="抽奖中心" FontSize="32" FontWeight="SemiBold"/>
                <TextBlock Text="参与即有机会赢取丰厚奖品" FontSize="14" Opacity="0.6"/>
            </StackPanel>

            <Button x:ConnectionId='46' Grid.Column="1" VerticalAlignment="Center"                      
                    Style="{StaticResource DefaultButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72C;" FontSize="16"/>
                    <TextBlock Text="刷新列表"/>
                </StackPanel>
            </Button>
        </Grid>
        
        <Grid Grid.Row="1">
             <ProgressRing x:ConnectionId='26'                                            
                           HorizontalAlignment="Center" VerticalAlignment="Center" 
                           Width="50" Height="50"
                                                                                                                 />

             <GridView x:ConnectionId='27'                                              
                       SelectionMode="None"
                       IsItemClickEnabled="False"
                                                                                                              >
                <GridView.ItemTemplate>
                    <DataTemplate                            >
                        <Grid x:ConnectionId='30' Width="320" Height="400" CornerRadius="12" Margin="12,12,24,24"
                              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                              BorderThickness="1">
                            <Grid.Shadow>
                                <ThemeShadow />
                            </Grid.Shadow>
                            <Grid.Translation>0,0,32</Grid.Translation>
                            
                            <Grid.RowDefinitions>
                                <RowDefinition Height="160"/> <!-- Image Area -->
                                <RowDefinition Height="*"/>   <!-- Content -->
                                <RowDefinition Height="Auto"/> <!-- Action -->
                            </Grid.RowDefinitions>
                            
                            <!-- 1. Banner Image Area -->
                            <Grid Grid.Row="0" CornerRadius="12,12,0,0">
                                <!-- Fallback Background -->
                                <Grid Background="{ThemeResource SystemControlBackgroundBaseLowBrush}">
                                    <FontIcon Glyph="&#xE8F2;" FontSize="48" Opacity="0.2" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                </Grid>
                                
                                <!-- Actual Image -->
                                <Image x:ConnectionId='43'                                                                                                       Stretch="UniformToFill" 
                                                                                                               />
                                
                                <!-- Status Badge -->
                                <Grid VerticalAlignment="Top" HorizontalAlignment="Right" Margin="12">
                                    <Grid.Shadow>
                                        <ThemeShadow />
                                    </Grid.Shadow>
                                    <Grid.Translation>0,0,8</Grid.Translation>
                                    <Border x:ConnectionId='44'                                                                                     
                                            CornerRadius="4" Padding="8,4">
                                        <TextBlock x:ConnectionId='45'                            FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                    </Border>
                                </Grid>
                                
                                <!-- Gradient Overlay for text readability if needed, but we put text below -->
                            </Grid>

                            <!-- 2. Content Area -->
                            <StackPanel Grid.Row="1" Padding="16,12" Spacing="6">
                                <TextBlock x:ConnectionId='37'                       FontSize="16" FontWeight="Bold" 
                                           TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE8F2;" FontSize="14" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center"/>
                                    <TextBlock x:ConnectionId='42'                                  FontWeight="SemiBold" Foreground="{ThemeResource SystemAccentColor}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <TextBlock x:ConnectionId='38'                             TextWrapping="Wrap" MaxLines="2" 
                                           Opacity="0.7" FontSize="13" Height="40" 
                                           TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                                
                                <!-- Divider -->
                                <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8"/>
                                
                                <!-- Metadata -->
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <StackPanel Orientation="Horizontal" Spacing="4" Opacity="0.6">
                                            <FontIcon Glyph="&#xE787;" FontSize="12"/>
                                            <TextBlock x:ConnectionId='41'                           FontSize="12"/>
                                        </StackPanel>
                                        
                                        <!-- Prizes Summary -->
                                        <StackPanel Orientation="Horizontal" Spacing="4" Opacity="0.8">
                                            <FontIcon Glyph="&#xE71D;" FontSize="12"/> <!-- Gift icon -->
                                            <TextBlock x:ConnectionId='40'                                    FontSize="12" FontWeight="SemiBold"/>
                                            <TextBlock Text="份奖品" FontSize="12"/>
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <!-- Lock Icon if Protected -->
                                    <StackPanel x:ConnectionId='39' Grid.Column="1" VerticalAlignment="Bottom"                                                                            >
                                        <FontIcon Glyph="&#xE72E;" FontSize="16" Opacity="0.5" ToolTipService.ToolTip="需要口令"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <!-- 3. Action Area -->
                            <Grid Grid.Row="2" Padding="16,0,16,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Winner Info (Overlapping/Inline) -->
                                <StackPanel x:ConnectionId='31' Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0" 
                                                                                                                                >
                                    <TextBlock Text="已开奖" FontSize="12" Opacity="0.6"/>
                                    <TextBlock Text="点击查看名单" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource SystemAccentColor}"/>
                                </StackPanel>

                                <!-- Join Button -->
                                <Button x:ConnectionId='32' Grid.Column="0" Grid.ColumnSpan="2"
                                                                            
                                        HorizontalAlignment="Stretch"
                                                                          
                                                                                   
                                                                                                                     
                                        Style="{StaticResource AccentButtonStyle}"
                                        Height="36"/>
                                
                                <!-- Show Winners Button if Drawn -->
                                 <Button x:ConnectionId='33' Grid.Column="1" Content="查看名单" 
                                                                                   
                                                                                                                            
                                        Height="36"/>
                                        
                                <!-- Disabled Button for other states -->
                                <StackPanel x:ConnectionId='34' Grid.Column="0" Grid.ColumnSpan="2" 
                                                                                                                          >
                                     <StackPanel x:ConnectionId='35'                                                                                      >
                                        <Button x:ConnectionId='36'                                    
                                                HorizontalAlignment="Stretch"
                                                IsEnabled="False"
                                                Height="36"/>
                                     </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </GridView.ItemTemplate>
             </GridView>
             
             <!-- Empty State -->
             <StackPanel x:ConnectionId='28' VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16"
                                                                                                             >
                 <Border Background="{ThemeResource SystemControlBackgroundBaseLowBrush}" Width="100" Height="100" CornerRadius="50">
                     <FontIcon Glyph="&#xE77F;" FontSize="48" Opacity="0.3" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                 </Border>
                 <TextBlock Text="暂无抽奖活动" Opacity="0.5" FontSize="18"/>
             </StackPanel>
        </Grid>
        
        <!-- Details Dialog -->
        <ContentDialog x:ConnectionId='2' x:Name="LotteryDetailsDialog" 
                       Title="活动详情" 
                       PrimaryButtonText="立即参与" 
                       CloseButtonText="关闭"
                       DefaultButton="Primary"
                                                                                   >
            <ScrollViewer MaxHeight="500">
                <StackPanel Spacing="16" Width="400">
                    <!-- Title -->
                    <TextBlock x:ConnectionId='9'                                                    FontSize="20" FontWeight="Bold" TextWrapping="Wrap"/>
                    
                    <!-- Status -->
                    <Border x:ConnectionId='10' HorizontalAlignment="Left"                                                                                                                  
                            CornerRadius="4" Padding="8,4">
                        <TextBlock x:ConnectionId='25'                                                         FontSize="12" Foreground="White" FontWeight="SemiBold"/>
                    </Border>

                    <!-- Description -->
                    <StackPanel>
                        <TextBlock Text="活动介绍" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock x:ConnectionId='24'                                                          TextWrapping="Wrap" Opacity="0.8"/>
                    </StackPanel>

                    <!-- Prizes -->
                    <StackPanel>
                        <TextBlock Text="奖品设置" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        
                        <!-- Single Prize Fallback -->
                        <StackPanel x:ConnectionId='16'                                                                                                           
                                    Orientation="Horizontal" Spacing="8" Background="{ThemeResource LayerFillColorDefaultBrush}" Padding="12" CornerRadius="8">
                            <FontIcon Glyph="&#xE8F2;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}"/>
                            <StackPanel>
                                <TextBlock x:ConnectionId='22'                                                        FontWeight="SemiBold"/>
                                <TextBlock x:ConnectionId='23'                                                                                                                                          Opacity="0.6" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Multi Prize List -->
                        <ItemsControl x:ConnectionId='17'                                                            
                                                                                                                                               >
                            <ItemsControl.ItemTemplate>
                                <DataTemplate                                 >
                                     <Grid x:ConnectionId='19' Margin="0,4" Background="{ThemeResource LayerFillColorDefaultBrush}" Padding="12,8" CornerRadius="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Glyph="&#xE8F2;" FontSize="16" Foreground="{ThemeResource SystemAccentColor}" Margin="0,0,12,0"/>
                                        <TextBlock x:ConnectionId='20' Grid.Column="1"                      TextTrimming="CharacterEllipsis" FontWeight="SemiBold"/>
                                        <TextBlock x:ConnectionId='21' Grid.Column="2"                       Opacity="0.6"/>
                                        <TextBlock Grid.Column="2" Text="份" Opacity="0.6" Margin="16,0,0,0"/>
                                     </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Time -->
                    <StackPanel>
                        <TextBlock Text="活动时间" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <Grid ColumnSpacing="12" Background="{ThemeResource LayerFillColorDefaultBrush}" Padding="12" CornerRadius="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Opacity="0.6" Spacing="4">
                                <TextBlock Text="开始时间"/>
                                <TextBlock Text="开奖时间"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock x:ConnectionId='14'                                                                                                             />
                                <TextBlock x:ConnectionId='15'                                                                                                           />
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Password Input -->
                    <StackPanel x:ConnectionId='11' x:Name="DialogPasswordPanel"                                                                                                         >
                        <TextBlock Text="参与口令" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:ConnectionId='13' x:Name="DialogPasswordBox" PlaceholderText="请输入口令以参与活动"/>
                    </StackPanel>
                    
                    <!-- Error Message -->
                    <TextBlock x:ConnectionId='12' x:Name="DialogErrorMessage" Foreground="Red" Visibility="Collapsed" TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>
        </ContentDialog>
        
        <!-- Winners Dialog -->
        <ContentDialog x:ConnectionId='3' x:Name="WinnersDialog" Title="恭喜以下中奖用户" CloseButtonText="关闭" DefaultButton="Close">
            <ListView x:ConnectionId='4'                                             Height="300" Width="400" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate                                  >
                        <Grid x:ConnectionId='6' Padding="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Background="#FFF8E1" Margin="0,0,16,0">
                                <FontIcon Glyph="&#xE8F2;" Foreground="#FFB300" FontSize="20"/>
                            </Border>
                            
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:ConnectionId='8'                          FontWeight="Bold" FontSize="16"/>
                                <TextBlock Text="获得大奖" FontSize="12" Opacity="0.5"/>
                            </StackPanel>
                            
                            <TextBlock x:ConnectionId='7' Grid.Column="2"                       VerticalAlignment="Center" 
                                       Foreground="{ThemeResource SystemAccentColor}" FontWeight="SemiBold"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ContentDialog>
    </Grid>
</Page>

