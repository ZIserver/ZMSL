<Page x:ConnectionId='1'
    x:Class="ZMSL.App.Views.GroupServerListPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ZMSL.App.Views"
    xmlns:vm="using:ZMSL.App.ViewModels"
    xmlns:models="using:ZMSL.App.Models"
    xmlns:converters="using:ZMSL.App.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
                        >

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisible"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToCollapsed" Invert="True"/>
    </Page.Resources>

    <Grid Padding="40,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Margin="0,0,0,24">
            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <TextBlock Text="群组服务器管理" FontSize="32" FontWeight="Bold"/>
                
                <!-- View Toggle -->
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Bottom" Margin="0,0,0,6">
                    <Button x:ConnectionId='32' Padding="8" Background="Transparent" BorderThickness="0" 
                                                                              
                                                                                                                             
                            ToolTipService.ToolTip="切换到列表视图">
                        <FontIcon Glyph="&#xE8FD;" FontSize="16"/>
                    </Button>
                    <Button x:ConnectionId='33' Padding="8" Background="Transparent" BorderThickness="0" 
                                                                              
                                                                                                                               
                            ToolTipService.ToolTip="切换到卡片视图">
                        <FontIcon Glyph="&#xE80A;" FontSize="16"/>
                    </Button>
                </StackPanel>
            </StackPanel>
            
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8">
                <Button x:ConnectionId='30' Content="刷新"                                                      Padding="12,8"/>
                <Button x:ConnectionId='31' Content="创建群组服务器" Style="{StaticResource AccentButtonStyle}"                                                       Padding="16,8"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <!-- Card View -->
            <GridView x:ConnectionId='2'                                                            SelectionMode="None"
                                                                                                                       
                      IsItemClickEnabled="True"
                                                  >
                <GridView.ItemTemplate>
                    <DataTemplate                                    >
                        <Border x:ConnectionId='18' Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                                CornerRadius="12" Width="300" Margin="6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Info Area -->
                                <StackPanel Grid.Row="0" Padding="20">
                                    <!-- Header -->
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <Border Background="{ThemeResource AccentFillColorDefaultBrush}" 
                                                CornerRadius="8" Width="48" Height="48" Margin="0,0,16,0">
                                            <FontIcon Glyph="&#xE7F4;" FontSize="24" Foreground="White" 
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock x:ConnectionId='28'                      FontSize="18" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                            <Border Background="{ThemeResource SystemAccentColorLight2}" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" Margin="0,4,0,0">
                                                <TextBlock x:ConnectionId='29'                          FontSize="11" Foreground="White"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Attributes -->
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="8" Opacity="0.8">
                                            <FontIcon Glyph="&#xE7F8;" FontSize="14" Width="20"/>
                                            <TextBlock x:ConnectionId='27'                          FontSize="14"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="8" Opacity="0.8">
                                            <FontIcon Glyph="&#xE946;" FontSize="14" Width="20"/>
                                            <TextBlock x:ConnectionId='26'                                  FontSize="14"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="8" Opacity="0.8">
                                            <FontIcon Glyph="&#xE964;" FontSize="14" Width="20"/>
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <TextBlock x:ConnectionId='24'                             FontSize="14"/>
                                                <TextBlock Text="MB -" FontSize="14"/>
                                                <TextBlock x:ConnectionId='25'                             FontSize="14"/>
                                                <TextBlock Text="MB" FontSize="14"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Actions -->
                                <Border Grid.Row="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" 
                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="0,0,12,12">
                                    <Grid Padding="12,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <Button x:ConnectionId='19' Grid.Column="0" Content="管理" HorizontalAlignment="Stretch" 
                                                Style="{StaticResource AccentButtonStyle}"
                                                Command="{Binding ElementName=RootPage, Path=ViewModel.OpenServerDetailCommand}"                            />
                                                
                                        <Grid Grid.Column="1" Width="8"/>

                                        <Grid Grid.Column="2">
                                            <Button x:ConnectionId='22' Content="启动" HorizontalAlignment="Stretch"
                                                                                                                                            
                                                    Command="{Binding ElementName=RootPage, Path=ViewModel.StartServerCommand}"                            />
                                            <Button x:ConnectionId='23' Content="停止" HorizontalAlignment="Stretch"
                                                                                                                                          
                                                    Command="{Binding ElementName=RootPage, Path=ViewModel.StopServerCommand}"                            
                                                    Background="#C42B1C" Foreground="White"/>
                                        </Grid>
                                                
                                        <Grid Grid.Column="3" Width="8"/>

                                        <Button x:ConnectionId='20' Grid.Column="4" Content="插件" HorizontalAlignment="Stretch"
                                                                                         />

                                        <Grid Grid.Column="5" Width="8"/>
                                                
                                        <Button x:ConnectionId='21' Grid.Column="6" Content="删除" HorizontalAlignment="Stretch"
                                                Command="{Binding ElementName=RootPage, Path=ViewModel.DeleteServerCommand}"                            />
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <!-- List View -->
            <ListView x:ConnectionId='3'                                                            SelectionMode="None"
                                                                                                                         
                      IsItemClickEnabled="True"
                                                  >
                <ListView.ItemTemplate>
                    <DataTemplate                                    >
                        <Grid x:ConnectionId='6' Padding="12,24" Margin="0,4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/> <!-- Icon -->
                                <ColumnDefinition Width="200"/>  <!-- Name -->
                                <ColumnDefinition Width="100"/>  <!-- Location -->
                                <ColumnDefinition Width="120"/>  <!-- Core -->
                                <ColumnDefinition Width="100"/>  <!-- Version -->
                                <ColumnDefinition Width="150"/>  <!-- Memory -->
                                <ColumnDefinition Width="*"/>    <!-- Spacer -->
                                <ColumnDefinition Width="Auto"/> <!-- Actions -->
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="{ThemeResource AccentFillColorDefaultBrush}" 
                                    CornerRadius="6" Width="40" Height="40" Margin="0,0,16,0">
                                <FontIcon Glyph="&#xE7F4;" FontSize="20" Foreground="White" 
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            
                            <TextBlock x:ConnectionId='7' Grid.Column="1"                      VerticalAlignment="Center" FontWeight="SemiBold" FontSize="15" TextTrimming="CharacterEllipsis"/>
                            
                            <Border Grid.Column="2" Background="{ThemeResource SystemAccentColorLight2}" CornerRadius="4" Padding="8,2" 
                                    HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock x:ConnectionId='16'                          FontSize="12" Foreground="White"/>
                            </Border>
                            
                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Opacity="0.8">
                                <FontIcon Glyph="&#xE7F8;" FontSize="14"/>
                                <TextBlock x:ConnectionId='15'                          FontSize="14"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Opacity="0.8">
                                <FontIcon Glyph="&#xE946;" FontSize="14"/>
                                <TextBlock x:ConnectionId='14'                                  FontSize="14"/>
                            </StackPanel>

                            <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Opacity="0.8">
                                <FontIcon Glyph="&#xE964;" FontSize="14"/>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock x:ConnectionId='12'                             FontSize="14"/>
                                    <TextBlock Text="-" FontSize="14"/>
                                    <TextBlock x:ConnectionId='13'                             FontSize="14"/>
                                    <TextBlock Text="MB" FontSize="14"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="7" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Button Content="管理" Command="{Binding ElementName=RootPage, Path=ViewModel.OpenServerDetailCommand}" CommandParameter="{Binding}" Padding="12,6"/>
                                <Button x:ConnectionId='8' Content="插件"                                           Padding="12,6"/>
                                <Button x:ConnectionId='9' Content="启动" Style="{StaticResource AccentButtonStyle}" Padding="16,6"
                                                                                                                                
                                        Command="{Binding ElementName=RootPage, Path=ViewModel.StartServerCommand}"                            />
                                <Button x:ConnectionId='10' Content="停止" Padding="16,6"
                                                                                                                              
                                        Command="{Binding ElementName=RootPage, Path=ViewModel.StopServerCommand}"                            
                                        Background="#C42B1C" Foreground="White"/>
                                <Button x:ConnectionId='11' Content="删除" Padding="16,6"
                                        Command="{Binding ElementName=RootPage, Path=ViewModel.DeleteServerCommand}"                            />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            
            <ProgressRing x:ConnectionId='4'                                                      Width="50" Height="50" HorizontalAlignment="Center" VerticalAlignment="Center"                                                                                                 />
        </Grid>
    </Grid>
</Page>

