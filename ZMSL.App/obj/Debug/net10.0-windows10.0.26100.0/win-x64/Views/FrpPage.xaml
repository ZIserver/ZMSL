<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="ZMSL.App.Views.FrpPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:ZMSL.App.Converters"
                        >

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityInverse" Invert="True"/>
        <converters:StringToVisibilityConverter x:Key="StringVisibilityConverter"/>
        <converters:StringToVisibilityInverseConverter x:Key="StringVisibilityInverseConverter"/>
    </Page.Resources>

    <Grid Padding="40,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <!-- 页面标题 -->
        <StackPanel>
            <TextBlock Text="ZMSLFrp" FontSize="32" FontWeight="Bold"/>
            <TextBlock x:ConnectionId='25' x:Name="LoginHint" Text="请先登录以使用ZMSLFrp功能" Opacity="0.7" Margin="0,8,0,0"/>
            
            <!-- 流量配额显示 -->
            <Border x:ConnectionId='26' x:Name="TrafficQuotaPanel" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" 
                    CornerRadius="8" Padding="16,12" Margin="0,16,0,0" Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE9F5;" FontSize="18" Opacity="0.8"/>
                        <TextBlock Text="流量配额" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <Grid Grid.Column="1" Margin="24,0">
                        <ProgressBar x:ConnectionId='30' x:Name="TrafficProgressBar" Value="0" Maximum="100" Height="8" 
                                     CornerRadius="4" Background="{ThemeResource ControlStrongFillColorDefaultBrush}"/>
                    </Grid>
                    
                    <TextBlock x:ConnectionId='27' x:Name="TrafficText" Grid.Column="2" VerticalAlignment="Center" FontFamily="Consolas">
                        <Run x:ConnectionId='28' x:Name="TrafficUsedRun" Text="0 GB"/>
                        <Run Text=" / "/>
                        <Run x:ConnectionId='29' x:Name="TrafficQuotaRun" Text="0 GB"/>
                    </TextBlock>
                </Grid>
            </Border>
        </StackPanel>

        <!-- 连接状态卡片 -->
        <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="24" Margin="0,24,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- 左侧状态指示 -->
                <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <Ellipse x:ConnectionId='20' x:Name="StatusIndicator" Width="16" Height="16" Fill="Gray"/>
                    <StackPanel>
                        <TextBlock x:ConnectionId='21' x:Name="StatusText" Text="未连接" FontWeight="SemiBold" FontSize="18"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock x:ConnectionId='22' x:Name="CurrentTunnelText" Text="" Opacity="0.6" FontSize="13"/>
                            <StackPanel x:ConnectionId='23' x:Name="LatencyPanel" Orientation="Horizontal" Spacing="4" Visibility="Collapsed" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE9D2;" FontSize="12" Opacity="0.6"/>
                                <TextBlock x:ConnectionId='24' x:Name="LatencyValueText" Text="测速中..." FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
                
                <!-- 中间连接地址 -->
                <StackPanel Grid.Column="1" Margin="48,0" VerticalAlignment="Center">
                    <TextBlock Text="连接地址" Opacity="0.6" FontSize="12"/>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock x:ConnectionId='18' x:Name="ConnectAddressText" Text="-" FontSize="20" FontWeight="Bold" 
                                   FontFamily="Consolas" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                        <Button x:ConnectionId='19' x:Name="CopyAddressBtn" Content="复制" Padding="16,6" 
                                                          Visibility="Collapsed"/>
                    </StackPanel>
                </StackPanel>
                
                <!-- 右侧操作按钮 -->
                <Button x:ConnectionId='17' x:Name="StopButton" Grid.Column="2" Content="停止连接" 
                        Style="{StaticResource AccentButtonStyle}"                          IsEnabled="False"/>
            </Grid>
        </Border>

        <!-- 中间内容区 -->
        <Grid x:ConnectionId='2' Grid.Row="2" Margin="0,20,0,0" x:Name="MainContent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：创建隧道表单 -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="24">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="20">
                        <TextBlock Text="创建新隧道" FontWeight="SemiBold" FontSize="18"/>
                        
                        <StackPanel Spacing="16">
                            <ComboBox x:ConnectionId='11' x:Name="NodeComboBox" PlaceholderText="选择节点" HorizontalAlignment="Stretch" Height="40">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                            <Border Grid.Column="1" CornerRadius="4" Padding="8,2" Margin="8,0,0,0" Background="#10B981">
                                                <TextBlock Text="{Binding NodeGroupText}" FontSize="11" Foreground="White"/>                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBox x:ConnectionId='12' x:Name="TunnelNameBox" PlaceholderText="隧道名称" Height="40"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:ConnectionId='14' x:Name="ProtocolComboBox" SelectedIndex="0" Margin="0,0,8,0" HorizontalAlignment="Stretch" Height="40">
                                    <ComboBoxItem Content="TCP"/>
                                    <ComboBoxItem Content="UDP"/>
                                </ComboBox>
                                <NumberBox x:ConnectionId='15' x:Name="LocalPortBox" Value="25565" PlaceholderText="本地端口" Grid.Column="1" Margin="8,0,0,0" Height="40"/>
                            </Grid>
                            
                            <!-- 高级选项 -->
                            <CheckBox Content="启用 Proxy Protocol v2 (需后端支持)" IsChecked="{Binding EnableProxyProtocol, Mode=TwoWay}"
                                      ToolTipService.ToolTip="开启后可获取真实IP，但需要本地服务（如Nginx/MC）配置支持，否则会导致连接失败"/>

                            <Button x:ConnectionId='13' Content="创建隧道" Style="{StaticResource AccentButtonStyle}" 
                                    HorizontalAlignment="Stretch"                            Height="44" FontSize="15"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- 右侧：隧道列表 -->
            <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="20" Margin="20,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="我的隧道" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12"/>
                    <ListView x:ConnectionId='7' x:Name="TunnelListView" Grid.Row="1"                                                   >
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="12,10" Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="15"/>
                                            <Border Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="4" Padding="8,2">
                                                <TextBlock Text="{Binding Protocol}" FontSize="11" Foreground="White"/>
                                            </Border>
                                            <!-- 运行中标记 -->
                                            <Border Background="#10B981" CornerRadius="4" Padding="10,2" 
                                                    Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibility}}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <Ellipse Width="8" Height="8" Fill="White"/>
                                                    <TextBlock Text="运行中" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,4,0,0">
                                            <!-- 优先显示解析后的域名 -->
                                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                                                        Visibility="{Binding ResolvedDomain, Converter={StaticResource StringVisibilityConverter}}">
                                                <Border Background="#10B981" CornerRadius="4" Padding="6,0" Height="20" VerticalAlignment="Center">
                                                    <TextBlock Text="域名" FontSize="11" Foreground="White" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                                                </Border>
                                                <TextBlock FontWeight="Bold" FontSize="14" FontFamily="Consolas" VerticalAlignment="Center">
                                                    <Run Text="{Binding ResolvedDomain}"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <!-- 节点域名 (仅当没有解析域名时显示) -->
                                            <Grid Visibility="{Binding ResolvedDomain, Converter={StaticResource StringVisibilityInverseConverter}}">
                                                <TextBlock FontWeight="Bold" FontSize="14" FontFamily="Consolas" 
                                                           Visibility="{Binding NodeDomain, Converter={StaticResource StringVisibilityConverter}}">
                                                    <Run Text="{Binding NodeDomain}"/>
                                                </TextBlock>
                                            </Grid>
                                            
                                            <!-- IP地址 (小字) -->
                                            <TextBlock Opacity="0.6" FontSize="12" FontFamily="Consolas">
                                                <Run Text="IP: "/><Run Text="{Binding ConnectAddress}"/>
                                            </TextBlock>
                                            
                                            <TextBlock Opacity="0.6" FontSize="12" FontFamily="Consolas">
                                                <Run Text="本地: "/><Run Text="{Binding LocalPort}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding NodeName}" Opacity="0.5" FontSize="12"/>
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <Button x:ConnectionId='9' Grid.Column="1" Content="启动" Tag="{Binding}"                           
                                            Margin="12,0" Padding="20,8"
                                            Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityInverse}}"/>
                                    <Button x:ConnectionId='10' Grid.Column="2" Content="删除" Tag="{Binding}"                            Padding="16,8"
                                            Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityInverse}}"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <!-- 底部：日志 -->
        <Border Grid.Row="3" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="12" Padding="20" Margin="0,20,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <TextBlock Text="运行日志" FontWeight="SemiBold" FontSize="16"/>
                    <Button x:ConnectionId='6' Content="清空" Padding="12,4"                        />
                </StackPanel>
                <ScrollViewer Grid.Row="1" Margin="0,12,0,0" 
                              HorizontalScrollBarVisibility="Disabled" 
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:ConnectionId='4' x:Name="LogsControl" FontFamily="Consolas" FontSize="12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="Wrap" IsTextSelectionEnabled="True"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <ProgressRing x:ConnectionId='3' x:Name="LoadingRing" Grid.RowSpan="4" IsActive="False" Width="50" Height="50"/>
    </Grid>
</Page>

