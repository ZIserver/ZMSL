<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="ZMSL.App.Views.GroupServerDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ZMSL.App.Views"
    xmlns:vm="using:ZMSL.App.ViewModels"
    xmlns:converters="using:ZMSL.App.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
                        
                            >

    <Page.Resources>
        <converters:BoolToBrushConverter x:Key="SelectedBorderConverter" 
                                         TrueBrush="{ThemeResource SystemControlHighlightAccentBrush}"
                                         FalseBrush="Transparent"/>
        <converters:BoolNegationConverter x:Key="BoolNegationConverter"/>
        <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToCollapsed" Invert="True"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题栏 -->
        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="40,20" CornerRadius="0,0,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="20">
                    <Button x:ConnectionId='42'                    Padding="12,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                            <TextBlock Text="返回"/>
                        </StackPanel>
                    </Button>
                    <StackPanel>
                        <TextBlock x:ConnectionId='43'                                                   FontSize="24" FontWeight="Bold"/>
                        <TextBlock x:ConnectionId='44'                                                     Opacity="0.7" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10">
                    <Button x:ConnectionId='36'                                                                                                                                                         Style="{StaticResource AccentButtonStyle}" Padding="16,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE768;" FontSize="14"/>
                            <TextBlock Text="启动"/>
                        </StackPanel>
                    </Button>
                    <Button x:ConnectionId='37'                                                                                                      Padding="16,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE71A;" FontSize="14"/>
                            <TextBlock Text="停止"/>
                        </StackPanel>
                    </Button>
                    <Button x:ConnectionId='38'                                                                                                         Padding="16,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                            <TextBlock Text="重启"/>
                        </StackPanel>
                    </Button>
                    <Button x:ConnectionId='39' Content="子服务器"                                Padding="16,8"/>
                    <Button x:ConnectionId='40' Content="文件管理"                           Padding="16,8"/>
                    <Button x:ConnectionId='41' Content="群组设置"                                Padding="16,8"/>
                    
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Row="1" Padding="40,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <!-- 控制台 -->
            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="12" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="控制台" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12"/>
                    
                    <TextBox x:ConnectionId='31' x:Name="ConsoleOutput" 
                             Grid.Row="1" 
                                                                                 
                             FontFamily="Consolas" 
                             FontSize="12" 
                             IsReadOnly="True" 
                             TextWrapping="Wrap" 
                             AcceptsReturn="True" 
                             ScrollViewer.VerticalScrollBarVisibility="Auto" 
                                                                              >
                        <TextBox.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem x:ConnectionId='34' Text="复制"                          >
                                    <MenuFlyoutItem.Icon>
                                        <SymbolIcon Symbol="Copy"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem x:ConnectionId='35' Text="全选"                               >
                                    <MenuFlyoutItem.Icon>
                                        <SymbolIcon Symbol="SelectAll"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </TextBox.ContextFlyout>
                    </TextBox>
                    
                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBox x:ConnectionId='32' x:Name="CommandInput" 
                                 Grid.Column="0"
                                                                                                                         
                                 PlaceholderText="输入命令..." 
                                                                
                                                                        
                                                                   />
                        
                        <Button x:ConnectionId='33' Grid.Column="1" Content="发送" Margin="8,0,0,0"                                                />
                    </Grid>
                </Grid>
            </Border>

            <!-- 右侧面板 -->
            <StackPanel Grid.Column="1" Margin="20,0,0,0" Spacing="16">
                <!-- 资源监控 -->
                <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="资源占用" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,16"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="CPU"/>
                            <ProgressBar x:ConnectionId='30'                                                  Maximum="100" Grid.Column="1"/>
                            <TextBlock Text="N/A" Grid.Column="2" TextAlignment="Right" Opacity="0.5"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="内存"/>
                            <ProgressBar x:ConnectionId='28'                                                     Maximum="100" Grid.Column="1"/>
                            <TextBlock x:ConnectionId='29'                                                        Grid.Column="2" TextAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 玩家列表 -->
                <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <TextBlock Text="在线玩家" FontWeight="SemiBold" FontSize="16"/>
                            <TextBlock x:ConnectionId='27'                                                        HorizontalAlignment="Right" Opacity="0.7"/>
                        </Grid>
                        
                        <ListView x:ConnectionId='24'                                                       MaxHeight="150">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Server}" VerticalAlignment="Center" HorizontalAlignment="Right" Opacity="0.5" FontSize="12" Margin="0,0,8,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <TextBlock x:ConnectionId='25' Text="暂无在线玩家"                                                                                                                                              Opacity="0.5" HorizontalAlignment="Center" Margin="0,8"/>
                    </StackPanel>
                </Border>

                <!-- 子服务器列表 -->
                <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <TextBlock Text="子服务器" FontWeight="SemiBold" FontSize="16"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                <Button x:ConnectionId='22' Content="一键启动" FontSize="12" Padding="8,4"                                                        Style="{StaticResource AccentButtonStyle}" ToolTipService.ToolTip="启动所有已停止的子服务器"/>
                                <Button x:ConnectionId='23' Content="保存配置" FontSize="12" Padding="8,4"                                               />
                            </StackPanel>
                        </Grid>
                        
                        <ListView x:ConnectionId='14'                                                          MaxHeight="300" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate                              >
                                    <Grid x:ConnectionId='16' Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Spacing="2">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock x:ConnectionId='20'                             FontWeight="SemiBold" FontSize="14"/>
                                                <Border x:ConnectionId='21' Background="{ThemeResource SystemAccentColorLight2}" CornerRadius="4" Padding="4,0"                                                                                   VerticalAlignment="Center">
                                                    <TextBlock Text="主城" FontSize="10" Foreground="White"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock x:ConnectionId='19'                         FontSize="11" Opacity="0.6"/>
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                            <!-- Start Button -->
                                            <Button x:ConnectionId='17' Padding="6,4" Command="{Binding ElementName=RootPage, Path=ViewModel.StartSubServerCommand}"                            
                                                                                                                                            
                                                    ToolTipService.ToolTip="启动此子服务器">
                                                <FontIcon Glyph="&#xE768;" FontSize="12"/>
                                            </Button>
                                            
                                            <!-- Stop Button -->
                                            <Button x:ConnectionId='18' Padding="6,4" Command="{Binding ElementName=RootPage, Path=ViewModel.StopSubServerCommand}"                            
                                                                                                                                                      
                                                    Background="#C42B1C" Foreground="White"
                                                    ToolTipService.ToolTip="停止此子服务器">
                                                <FontIcon Glyph="&#xE71A;" FontSize="12"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        
                        <TextBlock Text="提示: 只有本地存在的子服务器才能在此控制启动/停止。" Opacity="0.5" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"/>
                        
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
        
        <!-- 浮动命令建议 Popup -->
        <Popup x:ConnectionId='2' x:Name="CommandSuggestionPopup" 
               Grid.RowSpan="2"
               IsLightDismissEnabled="False"
               IsOpen="False">
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Padding="4"
                    Width="500"
                    MaxHeight="300">
                <Border.Shadow>
                    <ThemeShadow />
                </Border.Shadow>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:ConnectionId='12' x:Name="SuggestionListView">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button x:ConnectionId='13' HorizontalAlignment="Stretch" 
                                        HorizontalContentAlignment="Left"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="12,8"
                                                                    
                                        Tag="{Binding}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Command}" FontWeight="SemiBold" FontSize="13"/>
                                        <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Popup>

        <!-- Sub Server Selection Dialog -->
        <ContentDialog x:ConnectionId='3' x:Name="SubServerSelectionDialog"
                       Title="选择子服务器"
                       PrimaryButtonText="确定"
                       CloseButtonText="取消"
                                                                                       >
            <ScrollViewer MaxHeight="400" MinWidth="400">
                <ItemsControl x:ConnectionId='4'                                                               >
                    <ItemsControl.ItemTemplate>
                        <DataTemplate                                     >
                            <Button x:ConnectionId='6' HorizontalAlignment="Stretch" 
                                    HorizontalContentAlignment="Stretch"
                                    Margin="0,0,0,5" Padding="0"
                                    Background="Transparent" BorderThickness="0"
                                                                           >
                                <Border x:ConnectionId='7' BorderThickness="2" CornerRadius="8" Padding="12"
                                        HorizontalAlignment="Stretch"
                                                                                                                                          
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="2" HorizontalAlignment="Left">
                                            <TextBlock x:ConnectionId='9'                             FontWeight="SemiBold" TextAlignment="Left"/>
                                            <TextBlock x:ConnectionId='10'                        FontSize="12" Opacity="0.6" TextAlignment="Left"/>
                                            
                                            <RadioButton x:ConnectionId='11' Content="设为主城" 
                                                         Margin="0,4,0,0"
                                                                                                       
                                                         GroupName="MainLobbyGroup"
                                                         FontSize="12"
                                                                                    
                                                                                                                                                            
                                                                       />
                                        </StackPanel>
                                        <FontIcon x:ConnectionId='8' Glyph="&#xE73E;" FontSize="16" 
                                                                                                                                                      
                                                  Foreground="{ThemeResource SystemControlHighlightAccentBrush}" 
                                                  Grid.Column="1" VerticalAlignment="Top" Margin="0,4,0,0"/>
                                    </Grid>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </ContentDialog>
    </Grid>
</Page>

