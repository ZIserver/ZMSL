<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ZMSL.App.Views.FileManagerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题栏 -->
        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="40,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="20">
                    <Button x:ConnectionId='9'                    Padding="12,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                            <TextBlock Text="返回"/>
                        </StackPanel>
                    </Button>
                    <StackPanel>
                        <TextBlock x:ConnectionId='10' x:Name="TitleText" Text="文件管理" FontSize="24" FontWeight="Bold"/>
                        <TextBlock x:ConnectionId='11' x:Name="PathText" Text="根目录" Opacity="0.7" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10">
                    <Button x:ConnectionId='6'                      Padding="16,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE74E;" FontSize="14"/>
                            <TextBlock Text="上传文件"/>
                        </StackPanel>
                    </Button>
                    <Button x:ConnectionId='7'                          Padding="16,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE74A;" FontSize="14"/>
                            <TextBlock Text="返回上级"/>
                        </StackPanel>
                    </Button>
                    <Button x:ConnectionId='8'                       Padding="16,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                            <TextBlock Text="刷新"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Row="1" Padding="40,24">
            <!-- 文件列表 -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                    CornerRadius="12" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 列表头部 -->
                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="0,0,0,1" Padding="20,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="名称" FontWeight="SemiBold" Opacity="0.7"/>
                            <TextBlock Grid.Column="2" Text="大小" FontWeight="SemiBold" Opacity="0.7"/>
                            <TextBlock Grid.Column="3" Text="类型" FontWeight="SemiBold" Opacity="0.7"/>
                        </Grid>
                    </Border>

                    <!-- 文件列表内容 -->
                    <ListView x:ConnectionId='3' x:Name="FileListView" Grid.Row="1" 
                              SelectionMode="Single"
                              IsItemClickEnabled="True"
                                                            >
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="20,12" Height="60">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 图标 -->
                                    <Border Grid.Column="0" Width="32" Height="32" 
                                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                                            CornerRadius="6" VerticalAlignment="Center">
                                        <FontIcon Glyph="{Binding IconGlyph}" 
                                                  FontSize="16" Foreground="White"/>
                                    </Border>

                                    <!-- 名称 -->
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" 
                                               FontSize="14" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>

                                    <!-- 大小 -->
                                    <TextBlock Grid.Column="2" Text="{Binding SizeText}" 
                                               FontSize="13" Opacity="0.7"
                                               VerticalAlignment="Center"/>

                                    <!-- 类型 -->
                                    <TextBlock Grid.Column="3" Text="{Binding TypeText}" 
                                               FontSize="13" Opacity="0.7"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- 空状态提示 -->
                    <StackPanel x:ConnectionId='4' x:Name="EmptyHint" Grid.Row="1" 
                                VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="Collapsed">
                        <FontIcon Glyph="&#xE8B7;" FontSize="64" Opacity="0.2"/>
                        <TextBlock Text="此文件夹为空" FontSize="16" Opacity="0.5" 
                                   Margin="0,16,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 加载指示器 -->
            <Grid x:ConnectionId='2' x:Name="LoadingOverlay" Background="{ThemeResource LayerFillColorDefaultBrush}" 
                  Visibility="Collapsed">
                <ProgressRing IsActive="True" Width="48" Height="48"/>
            </Grid>
        </Grid>
    </Grid>
</Page>

