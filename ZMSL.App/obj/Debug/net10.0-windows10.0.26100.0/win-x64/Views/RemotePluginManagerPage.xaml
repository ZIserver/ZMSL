<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ZMSL.App.Views.RemotePluginManagerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题栏 -->
        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="40,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="20">
                    <Button x:ConnectionId='21'                    Padding="12,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                            <TextBlock Text="返回"/>
                        </StackPanel>
                    </Button>
                    <StackPanel>
                        <TextBlock Text="插件管理" FontSize="24" FontWeight="Bold"/>
                        <TextBlock x:ConnectionId='22' x:Name="ServerNameText" Text="" Opacity="0.7" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10">
                    <Button x:ConnectionId='19'                       Padding="12,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                            <TextBlock Text="刷新"/>
                        </StackPanel>
                    </Button>
                    <Button x:ConnectionId='20'                            Padding="12,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE898;" FontSize="14"/>
                            <TextBlock Text="上传插件"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主内容区：左右布局 -->
        <Grid Grid.Row="1" Padding="40,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：已安装的本地插件 -->
            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="12" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
                        <FontIcon Glyph="&#xE8F1;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}"/>
                        <TextBlock Text="已安装的插件" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock x:ConnectionId='18' x:Name="InstalledCountText" Text="(0)" Opacity="0.6" FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>

                    <ComboBox x:ConnectionId='12' x:Name="LocalFilterCombo" Grid.Row="1" Width="120" Margin="0,0,0,12"                                       >
                        <ComboBoxItem Content="全部" IsSelected="True"/>
                        <ComboBoxItem Content="已启用"/>
                        <ComboBoxItem Content="已禁用"/>
                    </ComboBox>

                    <ScrollViewer Grid.Row="2">
                        <ItemsControl x:ConnectionId='15' x:Name="LocalPluginList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                            CornerRadius="8" Padding="16" Margin="0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Ellipse Width="10" Height="10" Margin="0,0,12,0" VerticalAlignment="Center"
                                                     Fill="{Binding StatusBrush}"/>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="14"/>
                                                <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,2,0,0">
                                                    <TextBlock Text="{Binding FileName}" Opacity="0.6" FontSize="11"/>
                                                    <TextBlock Text="{Binding SizeText}" Opacity="0.5" FontSize="11"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <Button x:ConnectionId='17'                            Padding="8,6" ToolTipService.ToolTip="删除">
                                                    <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel x:ConnectionId='13' x:Name="LocalEmptyPanel" Grid.Row="2"
                                HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
                        <FontIcon Glyph="&#xE8B7;" FontSize="48" Opacity="0.3"/>
                        <TextBlock Text="暂无已安装的插件" FontSize="14" Opacity="0.5" Margin="0,12,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <ProgressRing x:ConnectionId='14' x:Name="LocalLoadingRing" Grid.Row="2"
                                  IsActive="False" Width="40" Height="40"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- 右侧：Modrinth插件商店 -->
            <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="12" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
                        <FontIcon Glyph="&#xE719;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}"/>
                        <TextBlock Text="Modrinth 插件" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock x:ConnectionId='11' x:Name="OnlineCountText" Text="(0)" Opacity="0.6" FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBox x:ConnectionId='2' x:Name="OnlineSearchBox" Grid.Row="1" PlaceholderText="搜索插件后按回车..." Margin="0,0,0,12"
                                                           />

                    <ScrollViewer Grid.Row="2">
                        <ItemsControl x:ConnectionId='8' x:Name="OnlinePluginList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                            CornerRadius="8" Padding="16" Margin="0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"/>
                                                    <TextBlock Text="{Binding DownloadsText}" Opacity="0.5" FontSize="11" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Author}" Opacity="0.6" FontSize="11" Margin="0,2,0,0"/>
                                                <TextBlock Text="{Binding Versions}" Opacity="0.5" FontSize="10" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <Button x:ConnectionId='10' Grid.Column="1" Content="{Binding InstallText}"
                                                                               
                                                    Style="{StaticResource AccentButtonStyle}"
                                                    Padding="16,6" FontSize="12"
                                                    IsEnabled="{Binding CanInstall}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- 分页控件 -->
                    <Border Grid.Row="3" Margin="0,12,0,0" Padding="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16">
                            <Button x:ConnectionId='5' x:Name="PrevPageBtn"                        Padding="12,6" IsEnabled="False">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE76B;" FontSize="12"/>
                                    <TextBlock Text="上一页" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <TextBlock x:ConnectionId='6' x:Name="PageInfoText" Text="1 / 1" VerticalAlignment="Center" FontSize="13" Opacity="0.8"/>
                            <Button x:ConnectionId='7' x:Name="NextPageBtn"                        Padding="12,6" IsEnabled="False">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="下一页" FontSize="12"/>
                                    <FontIcon Glyph="&#xE76C;" FontSize="12"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <ProgressRing x:ConnectionId='3' x:Name="OnlineLoadingRing" Grid.Row="2"
                                  IsActive="False" Width="40" Height="40"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <StackPanel x:ConnectionId='4' x:Name="OnlineEmptyPanel" Grid.Row="2"
                                HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
                        <FontIcon Glyph="&#xE774;" FontSize="48" Opacity="0.3"/>
                        <TextBlock Text="暂无可用插件" FontSize="14" Opacity="0.5" Margin="0,12,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>

