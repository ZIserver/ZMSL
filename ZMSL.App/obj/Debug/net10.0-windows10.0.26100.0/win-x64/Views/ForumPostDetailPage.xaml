<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="ZMSL.App.Views.ForumPostDetailPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:dto="using:ZMSL.Shared.DTOs"
    xmlns:vm="using:ZMSL.App.ViewModels"
    xmlns:converters="using:ZMSL.App.Converters"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </Page.Resources>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 主内容区域（居中对齐，限制宽度） -->
        <Grid Grid.RowSpan="3" MaxWidth="1000" HorizontalAlignment="Center" Width="1000">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 成功提示 (InfoBar) -->
            <InfoBar x:ConnectionId='2'                                                       
                     Severity="Success"
                     Title="成功"
                                                                             
                     VerticalAlignment="Top"
                     HorizontalAlignment="Center"
                     Width="400"
                     Margin="0,80,0,0"
                     Canvas.ZIndex="100"
                     Grid.RowSpan="3"/>

            <!-- 顶部导航 -->
            <Grid Grid.Row="0" Margin="0,24,0,24" Padding="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:ConnectionId='33' Style="{StaticResource NavigationBackButtonNormalStyle}"                         />
                <TextBlock Grid.Column="1" Text="帖子详情" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" Margin="16,0,0,0"/>
            </Grid>

            <ScrollViewer Grid.Row="1" Padding="24,0,24,24">
                <StackPanel Spacing="24">
                    <!-- 帖子内容 -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="24,20">
                        <StackPanel Spacing="12">
                            <!-- 标题 -->
                            <TextBlock Text="{Binding Post.Title}" FontSize="24" FontWeight="Bold" TextWrapping="Wrap"/>
                            
                            <!-- 元数据栏 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Border Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="4" Padding="6,2">
                                        <TextBlock Text="{Binding Post.CategoryName}" FontSize="12" Foreground="White"/>
                                    </Border>
                                    <TextBlock Text="{Binding Post.Username}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    <TextBlock Text="·" VerticalAlignment="Center" Opacity="0.5"/>
                                    <TextBlock Text="{Binding Post.CreatedAt}" VerticalAlignment="Center" Opacity="0.5" FontSize="12"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                    <Button Command="{Binding LikePostCommand}" Style="{StaticResource DateTimePickerFlyoutButtonStyle}" Padding="8,4" ToolTipService.ToolTip="点赞">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xEB51;" FontSize="16" Foreground="{Binding Post.IsLiked, Converter={StaticResource BoolToColorConverter}, ConverterParameter=Red}"/>
                                            <TextBlock Text="{Binding Post.LikeCount}"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding FavoritePostCommand}" Style="{StaticResource DateTimePickerFlyoutButtonStyle}" Padding="8,4" ToolTipService.ToolTip="收藏">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xE734;" FontSize="16" Foreground="{Binding Post.IsFavorited, Converter={StaticResource BoolToColorConverter}, ConverterParameter=Yellow}"/>
                                            <TextBlock Text="{Binding Post.FavoriteCount}"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4"/>

                            <!-- 正文 -->
                            <TextBlock x:ConnectionId='32' x:Name="PostContentText"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,16"
                                       IsTextSelectionEnabled="True"/>
                        </StackPanel>
                    </Border>

                    <!-- 分割线 -->
                            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8"/>

                            <!-- 评论区容器 -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="24,20">
                        <StackPanel Spacing="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock Text="评论" FontSize="20" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding Post.CommentCount}" VerticalAlignment="Center" Opacity="0.6"/>
                                    <TextBlock Text="条评论" VerticalAlignment="Center" Opacity="0.6"/>
                                </StackPanel>
                            </Grid>
                        
                            <!-- 空状态提示 -->
                            <StackPanel Visibility="{Binding HasComments, Converter={StaticResource BoolToVisibilityInverse}}" 
                                        HorizontalAlignment="Center" Spacing="12" Margin="0,32">
                                <FontIcon Glyph="&#xE7E7;" FontSize="48" Opacity="0.2"/>
                                <TextBlock Text="暂无评论，快来发表第一条评论吧~" Opacity="0.5" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- 评论列表 -->
                            <ItemsControl ItemsSource="{Binding Comments}" Visibility="{Binding HasComments, Converter={StaticResource BoolToVisibility}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate                                          >
                                        <StackPanel x:ConnectionId='4' Margin="0,0,0,16">
                                            <!-- 主评论卡片 -->
                                            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="8" Padding="16" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    
                                                    <!-- 评论者信息 -->
                                                    <Grid Grid.Row="0" Margin="0,0,0,12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <PersonPicture x:ConnectionId='28'                                                                       Width="32" Height="32" Margin="0,0,12,0"/>
                                                        
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock x:ConnectionId='30'                          FontWeight="SemiBold" FontSize="14"/>
                                                            <TextBlock x:ConnectionId='31'                           FontSize="12" Opacity="0.5"/>
                                                        </StackPanel>
                                                        
                                                        <TextBlock x:ConnectionId='29' Grid.Column="2"                    Opacity="0.3" FontSize="12" VerticalAlignment="Top"/>
                                                    </Grid>
 
                                                    <!-- 评论内容 -->
                                                    <TextBlock x:ConnectionId='5' Grid.Row="1"                         TextWrapping="Wrap" Margin="44,0,0,12" FontSize="15" LineHeight="24"/>
 
                                                    <!-- 操作栏 -->
                                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="16" HorizontalAlignment="Right">
                                                        <!-- 回复按钮 -->
                                                        <Button x:ConnectionId='24'                                          Style="{StaticResource DateTimePickerFlyoutButtonStyle}" Padding="8,4" ToolTipService.ToolTip="回复">
                                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                                <FontIcon Glyph="&#xE97A;" FontSize="14"/>
                                                                <TextBlock Text="回复" FontSize="12"/>
                                                            </StackPanel>
                                                        </Button>
                                                        
                                                        <!-- 点赞按钮 -->
                                                        <Button x:ConnectionId='25' Command="{Binding ElementName=RootPage, Path=DataContext.LikeCommentCommand}" 
                                                                                            Style="{StaticResource DateTimePickerFlyoutButtonStyle}" Padding="8,4">
                                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                                <FontIcon x:ConnectionId='26' Glyph="&#xEB51;" FontSize="14"                                                                                                       />
                                                                <TextBlock x:ConnectionId='27'                           FontSize="12"/>
                                                            </StackPanel>
                                                        </Button>
                                                    </StackPanel>
                                                    
                                                    <!-- 回复输入框 (可见性绑定) -->
                                                    <StackPanel x:ConnectionId='6' Grid.Row="3" Margin="44,12,0,0"                                                                                                  >
                                                        <TextBox x:ConnectionId='21'                                                                                
                                                                 PlaceholderText="写下你的回复..." AcceptsReturn="True" Height="80" Margin="0,0,0,8"/>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                                            <Button x:ConnectionId='22' Content="取消"                                         />
                                                            <Button x:ConnectionId='23' Content="发表回复" Style="{StaticResource AccentButtonStyle}"                                      />
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <!-- 嵌套回复列表 (移入卡片内部) -->
                                                    <StackPanel x:ConnectionId='7' Grid.Row="4" Margin="24,16,0,0"                                                                                             >
                                                        <!-- 分割线 -->
                                                        <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,0,0,16" Opacity="0.5"/>
                                                        
                                                        <ItemsControl x:ConnectionId='8'                                                   >
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate                                          >
                                                                    <Grid x:ConnectionId='11' Margin="0,0,0,16">
                                                                        <Grid.RowDefinitions>
                                                                            <RowDefinition Height="Auto"/>
                                                                            <RowDefinition Height="Auto"/>
                                                                            <RowDefinition Height="Auto"/>
                                                                        </Grid.RowDefinitions>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="32"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        
                                                                        <!-- 头像 -->
                                                                        <PersonPicture x:ConnectionId='12'                                                                       Width="24" Height="24" Grid.Row="0" Grid.Column="0" VerticalAlignment="Top" Margin="0,2,0,0"/>
                                                                        
                                                                        <!-- 内容区域 -->
                                                                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,0">
                                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                                <TextBlock x:ConnectionId='19'                          FontWeight="SemiBold" FontSize="13"/>
                                                                                <TextBlock x:ConnectionId='20'                           FontSize="12" Opacity="0.5"/>
                                                                            </StackPanel>
                                                                            <TextBlock x:ConnectionId='13'                         TextWrapping="Wrap" FontSize="14" Margin="0,4,0,0" Opacity="0.9"/>
                                                                            
                                                                            <!-- 回复操作栏 (简化) -->
                                                                            <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,4,0,0">
                                                                                <Button x:ConnectionId='18'                                          Content="回复" Style="{StaticResource TextBlockButtonStyle}" FontSize="12" Padding="0" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                                                                            </StackPanel>
                                                                            
                                                                            <!-- 嵌套回复的回复输入框 -->
                                                                            <StackPanel x:ConnectionId='14' Margin="0,8,0,0"                                                                                                  >
                                                                                <TextBox x:ConnectionId='15'                                                                                
                                                                                         PlaceholderText="回复..." Height="60" Margin="0,0,0,8"/>
                                                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                                                                    <Button x:ConnectionId='16' Content="取消"                                          FontSize="12"/>
                                                                                    <Button x:ConnectionId='17' Content="发表" Style="{StaticResource AccentButtonStyle}"                                       FontSize="12"/>
                                                                                </StackPanel>
                                                                            </StackPanel>
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        
                                                        <!-- 展开/收起回复按钮 -->
                                                        <Button x:ConnectionId='9'                                                   
                                                                                                       
                                                                                                                                                                
                                                                Style="{StaticResource TextBlockButtonStyle}"
                                                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                                Margin="40,0,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- 分页 -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16" Margin="0,16,0,0"
                                        Visibility="{Binding HasComments, Converter={StaticResource BoolToVisibility}}">
                                <Button Content="上一页" Command="{Binding PreviousPageCommand}" IsEnabled="{Binding CanGoPrevious}"/>
                                <TextBlock Text="{Binding CurrentPage}" VerticalAlignment="Center"/>
                                <TextBlock Text="/" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding TotalPages}" VerticalAlignment="Center"/>
                                <Button Content="下一页" Command="{Binding NextPageCommand}" IsEnabled="{Binding CanGoNext}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- 底部回复框 (全宽背景，限宽内容) -->
        <Grid Grid.Row="2" Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid MaxWidth="1000" HorizontalAlignment="Center" Width="1000" Padding="24,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Text="{Binding CommentContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                         PlaceholderText="分享你的想法..." AcceptsReturn="True" MaxHeight="100" Margin="0,0,16,0"/>
                <Button Grid.Column="1" Content="发表评论" Command="{Binding SubmitCommentCommand}" Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Bottom"/>
            </Grid>
        </Grid>

        <!-- 加载遮罩 -->
        <Grid Grid.RowSpan="3" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Opacity="0.8"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <ProgressRing Width="64" Height="64" IsActive="True"/>
        </Grid>

        <!-- 错误提示 -->
        <Grid Grid.RowSpan="3" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
              Visibility="{Binding StatusMessage, Converter={StaticResource NullToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                <FontIcon Glyph="&#xE783;" FontSize="48" Foreground="Red"/>
                <TextBlock Text="{Binding StatusMessage}" FontSize="16" Foreground="Red" TextWrapping="Wrap" MaxWidth="300" HorizontalTextAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>

