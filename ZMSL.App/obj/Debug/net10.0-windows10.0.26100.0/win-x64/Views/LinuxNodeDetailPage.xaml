<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ZMSL.App.Views.LinuxNodeDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="40,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题和返回 -->
        <StackPanel Orientation="Horizontal" Spacing="20" Margin="0,0,0,24">
            <Button x:ConnectionId='12'                    Padding="12,8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                    <TextBlock Text="返回"/>
                </StackPanel>
            </Button>
            <StackPanel>
                <TextBlock x:ConnectionId='15' x:Name="NodeNameText" Text="节点详情" FontSize="28" FontWeight="Bold"/>
                <TextBlock x:ConnectionId='16' x:Name="NodeAddressText" Text="连接地址" Opacity="0.6"/>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center" Margin="20,0,0,0">
                <Button x:ConnectionId='13'                         >
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8B7;" FontSize="14"/>
                        <TextBlock Text="Java 管理"/>
                    </StackPanel>
                </Button>
                <Button x:ConnectionId='14'                      >
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                        <TextBlock Text="刷新数据"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>

        <!-- 资源监控 -->
        <Grid Grid.Row="1" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="24" Margin="0,0,12,0">
                <StackPanel Spacing="12">
                    <TextBlock Text="CPU 使用率" Opacity="0.7"/>
                    <TextBlock x:ConnectionId='10' x:Name="CpuText" Text="0%" FontSize="32" FontWeight="Bold"/>
                    <ProgressBar x:ConnectionId='11' x:Name="CpuProgress" Value="0" Height="4"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="24" Margin="12,0">
                <StackPanel Spacing="12">
                    <TextBlock Text="内存使用" Opacity="0.7"/>
                    <TextBlock x:ConnectionId='8' x:Name="RamText" Text="0 / 0 GB" FontSize="24" FontWeight="Bold"/>
                    <ProgressBar x:ConnectionId='9' x:Name="RamProgress" Value="0" Height="4"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="24" Margin="12,0,0,0">
                <StackPanel Spacing="12">
                    <TextBlock Text="系统信息" Opacity="0.7"/>
                    <TextBlock x:ConnectionId='6' x:Name="OsText" Text="Linux" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock x:ConnectionId='7' x:Name="ArchText" Text="x86_64" Opacity="0.6" FontSize="13"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 磁盘信息 -->
        <Border Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="24" Margin="0,0,0,24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center" Margin="0,0,24,0">
                    <TextBlock Text="磁盘空间" Opacity="0.7"/>
                    <TextBlock x:ConnectionId='5' x:Name="DiskText" Text="0 / 0 GB" FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>
                <ProgressBar x:ConnectionId='3' x:Name="DiskProgress" Grid.Column="1" Value="0" Height="12" CornerRadius="6" VerticalAlignment="Center"/>
                <TextBlock x:ConnectionId='4' x:Name="DiskPercentText" Grid.Column="2" Text="0%" Margin="16,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold"/>
            </Grid>
        </Border>

        <ProgressRing x:ConnectionId='2' x:Name="LoadingRing" Grid.RowSpan="3" IsActive="False" Width="60" Height="60"/>
    </Grid>
</Page>

