        <converters:NotificationIconConverter x:Key="NotificationIconConverter"/>
        <converters:StringFormatConverter x:Key="StringFormatConverter"/>
        <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
    </Page.Resources>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <StackPanel Orientation="Horizontal" Spacing="24">
                <PersonPicture x:ConnectionId='4'                                                             
                                                                                         
                             Height="80" Width="80"/>
                
                <StackPanel Spacing="8" VerticalAlignment="Center">
                    <TextBlock x:ConnectionId='5'                                                    
                             Style="{StaticResource TitleTextBlockStyle}"/>
                    
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border Background="{ThemeResource SystemControlBackgroundBaseLowBrush}" 
                                CornerRadius="4" Padding="8,2">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon Glyph="&#xE735;" FontSize="12"/>
                                <TextBlock x:ConnectionId='9'                                                                                                                                  
                                         FontSize="12"/>
                            </StackPanel>
                        </Border>
                        
                        <TextBlock x:ConnectionId='8'                                                  
                                 Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    </StackPanel>
                    
                    <!-- Experience Bar (Simple representation) -->
                    <ProgressBar x:ConnectionId='6'                                                         Maximum="100" Width="200" HorizontalAlignment="Left"/>
                    <TextBlock x:ConnectionId='7'                                                                                                                                         
                             FontSize="12" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                </StackPanel>
            </StackPanel>
            
            <Button x:ConnectionId='3' Content="退出登录"                                            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,20,0,0"/>
        </StackPanel>

