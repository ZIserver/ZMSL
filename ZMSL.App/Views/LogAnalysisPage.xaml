<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ZMSL.App.Views.LogAnalysisPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="Page_Loaded">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧面板：输入区 -->
        <Border Grid.Column="0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,1,0">
            <Grid Padding="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 标题 -->
                <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,24">
                    <TextBlock Text="MC 日志分析" FontSize="24" FontWeight="Bold"/>
                    <TextBlock Text="AI 智能分析崩溃报告和错误日志" Opacity="0.6" FontSize="13"/>
                </StackPanel>

                <!-- API 选择 -->
                <StackPanel Grid.Row="1" Spacing="8" Margin="0,0,0,16">
                    <TextBlock Text="AI 服务" FontWeight="SemiBold"/>
                    <ComboBox x:Name="ApiProviderComboBox"
                              HorizontalAlignment="Stretch"
                              SelectionChanged="ApiProviderComboBox_SelectionChanged">
                        <ComboBoxItem Tag="zhisui">智穗AI (推荐)</ComboBoxItem>
                        <ComboBoxItem Tag="custom">自定义 API</ComboBoxItem>
                    </ComboBox>

                    <!-- 自定义 API 配置 -->
                    <StackPanel x:Name="CustomApiPanel" Visibility="Collapsed" Spacing="8" Margin="0,8,0,0">
                        <TextBox x:Name="CustomApiUrlBox"
                                 Header="API 地址"
                                 PlaceholderText="https://api.openai.com/v1/chat/completions"/>
                        <PasswordBox x:Name="CustomApiKeyBox"
                                     Header="API 密钥"
                                     PlaceholderText="sk-..."/>
                        <TextBox x:Name="CustomModelBox"
                                 Header="模型"
                                 PlaceholderText="gpt-4o-mini"/>
                        <Button Content="保存配置" Click="SaveCustomConfig_Click" HorizontalAlignment="Right"/>
                    </StackPanel>
                </StackPanel>

                <!-- 分析类型 -->
                <StackPanel Grid.Row="2" Spacing="8" Margin="0,0,0,16">
                    <TextBlock Text="分析类型" FontWeight="SemiBold"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <RadioButton x:Name="TypeGeneralRadio" Content="通用分析" GroupName="AnalysisType"
                                     IsChecked="True" Tag="general" Grid.Row="0" Grid.Column="0"/>
                        <RadioButton x:Name="TypeCrash" Content="崩溃分析" GroupName="AnalysisType"
                                     Tag="crash" Grid.Row="0" Grid.Column="1"/>
                        <RadioButton x:Name="TypeError" Content="错误分析" GroupName="AnalysisType"
                                     Tag="error" Grid.Row="1" Grid.Column="0"/>
                        <RadioButton x:Name="TypePerformance" Content="性能分析" GroupName="AnalysisType"
                                     Tag="performance" Grid.Row="1" Grid.Column="1"/>
                        <RadioButton x:Name="TypeSecurity" Content="安全分析" GroupName="AnalysisType"
                                     Tag="security" Grid.Row="2" Grid.Column="0"/>
                    </Grid>
                </StackPanel>

                <!-- 日志输入 -->
                <Grid Grid.Row="3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="日志/报错内容" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4">
                            <Button Click="PasteLog_Click" ToolTipService.ToolTip="粘贴" Padding="8">
                                <FontIcon Glyph="&#xE77F;" FontSize="12"/>
                            </Button>
                            <Button Click="ClearLog_Click" ToolTipService.ToolTip="清空" Padding="8">
                                <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <TextBox x:Name="LogContentBox"
                             Grid.Row="1"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             PlaceholderText="在此粘贴服务器日志、崩溃报告或错误信息..."
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="12"/>
                </Grid>

                <!-- 分析按钮 -->
                <Grid Grid.Row="4" Margin="0,16,0,0">
                    <Button x:Name="AnalyzeButton"
                            HorizontalAlignment="Stretch"
                            Height="48"
                            Click="Analyze_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE9D9;" FontSize="18"/>
                            <TextBlock Text="开始分析" FontSize="15" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="CancelButton"
                            HorizontalAlignment="Stretch"
                            Height="48"
                            Visibility="Collapsed"
                            Click="CancelAnalysis_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ProgressRing IsActive="True" Width="18" Height="18"/>
                            <TextBlock Text="分析中... 点击取消" FontSize="15"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <!-- 右侧面板：结果区 -->
        <Grid Grid.Column="1" Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 顶部工具栏 -->
            <Border Grid.Row="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    Padding="24,16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                                CornerRadius="8" Width="36" Height="36">
                            <FontIcon Glyph="&#xE8EF;" FontSize="16" Foreground="White"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="分析结果" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TokensUsedText" Text="等待分析..." Opacity="0.6" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                        <Button Click="CopyResult_Click" ToolTipService.ToolTip="复制结果">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8C8;" FontSize="14"/>
                                <TextBlock Text="复制"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 结果内容 -->
            <ScrollViewer Grid.Row="1" Padding="24">
                <Grid>
                    <!-- 空状态 -->
                    <StackPanel x:Name="EmptyStatePanel" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                        <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                CornerRadius="50" Width="100" Height="100"
                                HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE9D9;" FontSize="48" Opacity="0.4"/>
                        </Border>
                        <TextBlock Text="粘贴日志内容开始分析" FontSize="16" Opacity="0.6" HorizontalAlignment="Center"/>
                        <TextBlock Text="支持崩溃报告、错误日志、性能问题等" FontSize="13" Opacity="0.4" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- 分析结果卡片 -->
                    <Border x:Name="ResultPanel" Visibility="Collapsed"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="12" Padding="24">
                        <StackPanel Spacing="16">
                            <!-- 结果类型标签 -->
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                                        CornerRadius="4" Padding="12,4">
                                    <TextBlock x:Name="ResultTypeText" Text="通用分析" FontSize="12" Foreground="White" FontWeight="SemiBold"/>
                                </Border>
                                <TextBlock x:Name="ResultTimeText" Text="" Opacity="0.5" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- 结果内容 - 使用 RichTextBlock 支持 Markdown -->
                            <RichTextBlock x:Name="ResultRichText"
                                           TextWrapping="Wrap"
                                           IsTextSelectionEnabled="True"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
