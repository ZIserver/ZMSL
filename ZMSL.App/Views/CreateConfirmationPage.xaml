<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ZMSL.App.Views.CreateConfirmationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="Page_Loaded">

    <Grid Padding="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Border Background="{ThemeResource AccentFillColorDefaultBrush}" 
                        CornerRadius="8" Width="40" Height="40" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE710;" Foreground="White" FontSize="20"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="确认创建" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="检查配置并开始创建服务器" FontSize="12" Opacity="0.6"/>
                </StackPanel>
            </StackPanel>
            
            <!-- 步骤指示器 -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" 
                       Spacing="6" VerticalAlignment="Center">
                <Border Width="28" Height="3" Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="1.5"/>
                <Border Width="28" Height="3" Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="1.5"/>
                <Border Width="28" Height="3" Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="1.5"/>
            </StackPanel>
        </Grid>

        <!-- 配置摘要 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid HorizontalAlignment="Stretch" Margin="40,0">
                <StackPanel Spacing="20">
                    
                    <!-- 服务器基本信息 -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1">
                        <StackPanel Spacing="16">
                            <TextBlock Text="服务器信息" FontSize="18" FontWeight="SemiBold"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="服务器名称:" FontSize="14" Opacity="0.7"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="ServerNameText" Text="-" FontSize="14" FontWeight="SemiBold"/>
                                
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="创建模式:" FontSize="14" Opacity="0.7"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="ModeText" Text="-" FontSize="14" FontWeight="SemiBold"/>
                                
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="预计玩家:" FontSize="14" Opacity="0.7"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="PlayerCapacityText" Text="-" FontSize="14"/>
                                
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="服务器路径:" FontSize="14" Opacity="0.7"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="ServerPathText" Text="-" FontSize="14"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 核心配置 -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1">
                        <StackPanel Spacing="16">
                            <TextBlock Text="核心配置" FontSize="18" FontWeight="SemiBold"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="核心类型:" FontSize="14" Opacity="0.7"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="CoreTypeText" Text="-" FontSize="14" FontWeight="SemiBold"/>
                                
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="核心版本:" FontSize="14" Opacity="0.7"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="CoreVersionText" Text="-" FontSize="14"/>
                                
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Minecraft版本:" FontSize="14" Opacity="0.7"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="MinecraftVersionText" Text="-" FontSize="14"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 内存和性能配置 -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1">
                        <StackPanel Spacing="16">
                            <TextBlock Text="性能配置" FontSize="18" FontWeight="SemiBold"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="最小内存:" FontSize="14" Opacity="0.7"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="MinMemoryText" Text="-" FontSize="14"/>
                                
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="最大内存:" FontSize="14" Opacity="0.7"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="MaxMemoryText" Text="-" FontSize="14"/>
                                
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="服务器端口:" FontSize="14" Opacity="0.7"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="PortText" Text="-" FontSize="14"/>
                                
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Java路径:" FontSize="14" Opacity="0.7"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="JavaPathText" Text="系统默认" FontSize="14"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 高级配置（仅高手模式显示） -->
                    <Border x:Name="AdvancedConfigBorder" 
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1" Visibility="Collapsed">
                        <StackPanel Spacing="16">
                            <TextBlock Text="高级配置" FontSize="18" FontWeight="SemiBold"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="JVM参数:" FontSize="14" Opacity="0.7"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="JvmArgsText" Text="无" FontSize="14" TextWrapping="Wrap"/>
                                
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="自动接受EULA:" FontSize="14" Opacity="0.7"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="EulaText" Text="是" FontSize="14"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 创建进度 -->
                    <Border x:Name="ProgressBorder" 
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                            CornerRadius="8" Padding="20" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                            BorderThickness="1" Visibility="Collapsed">
                        <StackPanel Spacing="16">
                            <TextBlock Text="创建进度" FontSize="18" FontWeight="SemiBold"/>
                            
                            <ProgressBar x:Name="CreateProgressBar" IsIndeterminate="True" Height="6"/>
                            
                            <TextBlock x:Name="ProgressStatusText" Text="正在准备创建..." 
                                       FontSize="14" HorizontalAlignment="Center" Opacity="0.7"/>
                        </StackPanel>
                    </Border>

                    <!-- 错误信息 -->
                    <InfoBar x:Name="ErrorInfoBar" IsOpen="False" Severity="Error" 
                             Title="创建失败" Message="">
                        <InfoBar.ActionButton>
                            <Button Content="重试" Click="RetryButton_Click"/>
                        </InfoBar.ActionButton>
                    </InfoBar>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- 底部按钮栏 -->
        <Grid Grid.Row="2" Margin="0,24,0,0" 
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
              BorderThickness="0,1,0,0" Padding="16">
            <Grid HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Click="BackButton_Click" Padding="16,10">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                            <TextBlock Text="返回" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Click="CancelButton_Click" Padding="16,10">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE711;" FontSize="14"/>
                            <TextBlock Text="取消" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                
                <Button x:Name="CreateButton" Grid.Column="1"
                        Click="CreateButton_Click" 
                        Style="{StaticResource AccentButtonStyle}" 
                        Padding="24,10" MinWidth="120">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="创建服务器" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <FontIcon Glyph="&#xE72A;" FontSize="14"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</Page>