<Page
    x:Class="ZMSL.App.Views.GroupServerListPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ZMSL.App.Views"
    xmlns:vm="using:ZMSL.App.ViewModels"
    xmlns:models="using:ZMSL.App.Models"
    xmlns:converters="using:ZMSL.App.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="Page_Loaded">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisible"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToCollapsed" Invert="True"/>
    </Page.Resources>

    <Grid Padding="40,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Margin="0,0,0,24">
            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <TextBlock Text="群组服务器管理" FontSize="32" FontWeight="Bold"/>
                
                <!-- View Toggle -->
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Bottom" Margin="0,0,0,6">
                    <Button Padding="8" Background="Transparent" BorderThickness="0" 
                            Command="{x:Bind ViewModel.ToggleViewModeCommand}"
                            Visibility="{x:Bind ViewModel.IsCardView, Converter={StaticResource BoolToVisible}, Mode=OneWay}"
                            ToolTipService.ToolTip="切换到列表视图">
                        <FontIcon Glyph="&#xE8FD;" FontSize="16"/>
                    </Button>
                    <Button Padding="8" Background="Transparent" BorderThickness="0" 
                            Command="{x:Bind ViewModel.ToggleViewModeCommand}"
                            Visibility="{x:Bind ViewModel.IsCardView, Converter={StaticResource BoolToCollapsed}, Mode=OneWay}"
                            ToolTipService.ToolTip="切换到卡片视图">
                        <FontIcon Glyph="&#xE80A;" FontSize="16"/>
                    </Button>
                </StackPanel>
            </StackPanel>
            
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8">
                <Button Content="刷新" Command="{x:Bind ViewModel.LoadGroupServersCommand}" Padding="12,8"/>
                <Button Content="创建群组服务器" Style="{StaticResource AccentButtonStyle}" Command="{x:Bind ViewModel.CreateGroupServerCommand}" Padding="16,8"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <!-- Card View -->
            <GridView ItemsSource="{x:Bind ViewModel.GroupServers, Mode=OneWay}" SelectionMode="None"
                      Visibility="{x:Bind ViewModel.IsCardView, Converter={StaticResource BoolToVisible}, Mode=OneWay}"
                      IsItemClickEnabled="True"
                      ItemClick="ServerItem_Click">
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="models:ServerViewModel">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                                CornerRadius="12" Width="300" Margin="6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Info Area -->
                                <StackPanel Grid.Row="0" Padding="20">
                                    <!-- Header -->
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <Border Background="{ThemeResource AccentFillColorDefaultBrush}" 
                                                CornerRadius="8" Width="48" Height="48" Margin="0,0,16,0">
                                            <FontIcon Glyph="&#xE7F4;" FontSize="24" Foreground="White" 
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Name}" FontSize="18" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                            <Border Background="{ThemeResource SystemAccentColorLight2}" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" Margin="0,4,0,0">
                                                <TextBlock Text="{x:Bind Location}" FontSize="11" Foreground="White"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Attributes -->
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="8" Opacity="0.8">
                                            <FontIcon Glyph="&#xE7F8;" FontSize="14" Width="20"/>
                                            <TextBlock Text="{x:Bind CoreType}" FontSize="14"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="8" Opacity="0.8">
                                            <FontIcon Glyph="&#xE946;" FontSize="14" Width="20"/>
                                            <TextBlock Text="{x:Bind MinecraftVersion}" FontSize="14"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="8" Opacity="0.8">
                                            <FontIcon Glyph="&#xE964;" FontSize="14" Width="20"/>
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <TextBlock Text="{x:Bind MinMemoryMB}" FontSize="14"/>
                                                <TextBlock Text="MB -" FontSize="14"/>
                                                <TextBlock Text="{x:Bind MaxMemoryMB}" FontSize="14"/>
                                                <TextBlock Text="MB" FontSize="14"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Actions -->
                                <Border Grid.Row="1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" 
                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="0,0,12,12">
                                    <Grid Padding="12,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <Button Grid.Column="0" Content="管理" HorizontalAlignment="Stretch" 
                                                Style="{StaticResource AccentButtonStyle}"
                                                Command="{Binding ElementName=RootPage, Path=ViewModel.OpenServerDetailCommand}" CommandParameter="{x:Bind}"/>
                                                
                                        <Grid Grid.Column="1" Width="8"/>

                                        <Grid Grid.Column="2">
                                            <Button Content="启动" HorizontalAlignment="Stretch"
                                                    Visibility="{x:Bind IsRunning, Converter={StaticResource BoolToCollapsed}, Mode=OneWay}"
                                                    Command="{Binding ElementName=RootPage, Path=ViewModel.StartServerCommand}" CommandParameter="{x:Bind}"/>
                                            <Button Content="停止" HorizontalAlignment="Stretch"
                                                    Visibility="{x:Bind IsRunning, Converter={StaticResource BoolToVisible}, Mode=OneWay}"
                                                    Command="{Binding ElementName=RootPage, Path=ViewModel.StopServerCommand}" CommandParameter="{x:Bind}"
                                                    Background="#C42B1C" Foreground="White"/>
                                        </Grid>
                                                
                                        <Grid Grid.Column="3" Width="8"/>

                                        <Button Grid.Column="4" Content="插件" HorizontalAlignment="Stretch"
                                                Click="PluginButton_Click" Tag="{x:Bind}"/>

                                        <Grid Grid.Column="5" Width="8"/>
                                                
                                        <Button Grid.Column="6" Content="删除" HorizontalAlignment="Stretch"
                                                Command="{Binding ElementName=RootPage, Path=ViewModel.DeleteServerCommand}" CommandParameter="{x:Bind}"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <!-- List View -->
            <ListView ItemsSource="{x:Bind ViewModel.GroupServers, Mode=OneWay}" SelectionMode="None"
                      Visibility="{x:Bind ViewModel.IsCardView, Converter={StaticResource BoolToCollapsed}, Mode=OneWay}"
                      IsItemClickEnabled="True"
                      ItemClick="ServerItem_Click">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:ServerViewModel">
                        <Grid Padding="12,24" Margin="0,4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/> <!-- Icon -->
                                <ColumnDefinition Width="200"/>  <!-- Name -->
                                <ColumnDefinition Width="100"/>  <!-- Location -->
                                <ColumnDefinition Width="120"/>  <!-- Core -->
                                <ColumnDefinition Width="100"/>  <!-- Version -->
                                <ColumnDefinition Width="150"/>  <!-- Memory -->
                                <ColumnDefinition Width="*"/>    <!-- Spacer -->
                                <ColumnDefinition Width="Auto"/> <!-- Actions -->
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="{ThemeResource AccentFillColorDefaultBrush}" 
                                    CornerRadius="6" Width="40" Height="40" Margin="0,0,16,0">
                                <FontIcon Glyph="&#xE7F4;" FontSize="20" Foreground="White" 
                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            
                            <TextBlock Grid.Column="1" Text="{x:Bind Name}" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="15" TextTrimming="CharacterEllipsis"/>
                            
                            <Border Grid.Column="2" Background="{ThemeResource SystemAccentColorLight2}" CornerRadius="4" Padding="8,2" 
                                    HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Location}" FontSize="12" Foreground="White"/>
                            </Border>
                            
                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Opacity="0.8">
                                <FontIcon Glyph="&#xE7F8;" FontSize="14"/>
                                <TextBlock Text="{x:Bind CoreType}" FontSize="14"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Opacity="0.8">
                                <FontIcon Glyph="&#xE946;" FontSize="14"/>
                                <TextBlock Text="{x:Bind MinecraftVersion}" FontSize="14"/>
                            </StackPanel>

                            <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Opacity="0.8">
                                <FontIcon Glyph="&#xE964;" FontSize="14"/>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="{x:Bind MinMemoryMB}" FontSize="14"/>
                                    <TextBlock Text="-" FontSize="14"/>
                                    <TextBlock Text="{x:Bind MaxMemoryMB}" FontSize="14"/>
                                    <TextBlock Text="MB" FontSize="14"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="7" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Button Content="管理" Command="{Binding ElementName=RootPage, Path=ViewModel.OpenServerDetailCommand}" CommandParameter="{Binding}" Padding="12,6"/>
                                <Button Content="插件" Click="PluginButton_Click" Tag="{x:Bind}" Padding="12,6"/>
                                <Button Content="启动" Style="{StaticResource AccentButtonStyle}" Padding="16,6"
                                        Visibility="{x:Bind IsRunning, Converter={StaticResource BoolToCollapsed}, Mode=OneWay}"
                                        Command="{Binding ElementName=RootPage, Path=ViewModel.StartServerCommand}" CommandParameter="{x:Bind}"/>
                                <Button Content="停止" Padding="16,6"
                                        Visibility="{x:Bind IsRunning, Converter={StaticResource BoolToVisible}, Mode=OneWay}"
                                        Command="{Binding ElementName=RootPage, Path=ViewModel.StopServerCommand}" CommandParameter="{x:Bind}"
                                        Background="#C42B1C" Foreground="White"/>
                                <Button Content="删除" Padding="16,6"
                                        Command="{Binding ElementName=RootPage, Path=ViewModel.DeleteServerCommand}" CommandParameter="{x:Bind}"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" Width="50" Height="50" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{x:Bind ViewModel.IsLoading, Converter={StaticResource BoolToVisible}, Mode=OneWay}"/>
        </Grid>
    </Grid>
</Page>
