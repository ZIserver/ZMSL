<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ZMSL.App.Views.ModpackCoreSelectPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="Page_Loaded">

    <Grid Padding="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
            <Button Click="Back_Click" Padding="8" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE72B;" FontSize="16"/>
            </Button>
            <TextBlock Text="选择服务端核心" FontSize="32" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- 分隔线 -->
        <Border Grid.Row="1" Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="0,0,0,16"/>

        <!-- 主内容区域 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧:核心列表 -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="核心列表" FontWeight="SemiBold" Margin="8,8,8,12"/>

                    <ListView x:Name="CoreListView" Grid.Row="1"
                              SelectionMode="Single"
                              SelectionChanged="CoreListView_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Category}" FontSize="11" Opacity="0.6"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- 中间:游戏版本列表 -->
            <Border Grid.Column="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="游戏版本" FontWeight="SemiBold" Margin="8,8,8,12"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="VersionItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding}" Click="Version_Click"
                                            HorizontalAlignment="Stretch" Padding="12,10" Margin="0,0,0,4"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- 右侧:服务端信息卡片 -->
            <Border Grid.Column="4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="32">
                <Grid>
                    <StackPanel x:Name="ServerInfoPanel" Spacing="20" Visibility="Collapsed">
                        <!-- 图标 -->
                        <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                                CornerRadius="24" Width="80" Height="80"
                                HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE8F1;" Foreground="White" FontSize="40"/>
                        </Border>

                        <!-- 服务端名称 -->
                        <TextBlock x:Name="ServerNameText"
                                   Text="Paper"
                                   FontSize="28" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>

                        <!-- 服务端信息 -->
                        <StackPanel Spacing="12">
                            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                    CornerRadius="8" Padding="16,12">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="类型: " Opacity="0.6"/>
                                    <TextBlock x:Name="ServerCategoryText" Text="插件端" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                    CornerRadius="8" Padding="16,12">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="游戏版本: " Opacity="0.6"/>
                                    <TextBlock x:Name="ServerVersionText" Text="1.20.6" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- 整合包信息 -->
                        <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                CornerRadius="8" Padding="16,12">
                            <StackPanel Spacing="4">
                                <TextBlock Text="整合包信息" FontWeight="SemiBold" Opacity="0.8"/>
                                <TextBlock x:Name="ModpackNameText" Text="" FontSize="13" Opacity="0.7"/>
                                <TextBlock x:Name="ModpackServerNameText" Text="" FontSize="13" Opacity="0.7"/>
                            </StackPanel>
                        </Border>

                        <!-- 描述 -->
                        <TextBlock x:Name="ServerDescriptionText"
                                   Text="最流行的插件端，性能优异"
                                   TextWrapping="Wrap" Opacity="0.7"
                                   HorizontalAlignment="Center" TextAlignment="Center"/>

                        <!-- 创建按钮 -->
                        <Button x:Name="CreateButton" Click="Create_Click"
                                Style="{StaticResource AccentButtonStyle}"
                                HorizontalAlignment="Stretch" Height="56">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE710;" FontSize="20"/>
                                <TextBlock Text="创建服务器" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- 空状态 -->
                    <StackPanel x:Name="EmptyInfoHint"
                               VerticalAlignment="Center" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE9F3;" FontSize="48" Opacity="0.2"/>
                        <TextBlock Text="请选择核心和版本"
                                  Opacity="0.5" Margin="0,12,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- 下载进度面板 -->
        <Border Grid.Row="3" x:Name="DownloadPanel" Visibility="Collapsed"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0" Padding="16" Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="DownloadStatusText" Text="准备下载..." FontWeight="SemiBold"/>
                    <ProgressBar x:Name="DownloadProgressBar" Margin="0,8,0,0" Maximum="100" Height="4"/>
                </StackPanel>

                <Button Grid.Column="1" Click="Cancel_Click" Padding="16,10">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE711;" FontSize="14"/>
                        <TextBlock Text="取消"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Page>
