<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ZMSL.App.Views.LinuxNodePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:ZMSL.App.Models"
    xmlns:converters="using:ZMSL.App.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BooleanToStatusColorConverter x:Key="BooleanToStatusColorConverter"/>
        <converters:BooleanToStatusTextConverter x:Key="BooleanToStatusTextConverter"/>
        <converters:DateTimeFormatConverter x:Key="DateTimeFormatConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        
        <DataTemplate x:Key="NodeTemplate" x:DataType="models:LinuxNode">
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8" Padding="16" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧信息 -->
                    <StackPanel Grid.Column="0" Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="{x:Bind Name}" FontSize="18" FontWeight="SemiBold"/>
                            <!-- 平台标签 -->
                            <Border Background="{ThemeResource SystemAccentColorLight2}" CornerRadius="4" Padding="8,2">
                                <TextBlock Text="{x:Bind PlatformDisplayName}" FontSize="11" Foreground="White"/>
                            </Border>
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" 
                                         Fill="{x:Bind IsOnline, Converter={StaticResource BooleanToStatusColorConverter}, Mode=OneWay}"/>
                                <TextBlock Text="{x:Bind IsOnline, Converter={StaticResource BooleanToStatusTextConverter}, Mode=OneWay}"
                                           FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="地址: " FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind Host}" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text=":" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Text="{x:Bind Port}" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <TextBlock Text="{x:Bind LastConnectedAt, Converter={StaticResource DateTimeFormatConverter}, Mode=OneWay}"
                                       Visibility="{x:Bind LastConnectedAt, Converter={StaticResource NullToVisibilityConverter}, Mode=OneWay}"
                                       FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 右侧操作 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button Content="测试连接" Click="TestConnection_Click" DataContext="{x:Bind}"/>
                        <Button Content="管理" Click="ManageNode_Click" DataContext="{x:Bind}"/>
                        <Button Click="EditNode_Click" DataContext="{x:Bind}">
                            <FontIcon Glyph="&#xE70F;" FontSize="16"/>
                        </Button>
                        <Button Click="DeleteNode_Click" DataContext="{x:Bind}">
                            <FontIcon Glyph="&#xE74D;" FontSize="16"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部操作栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Padding="20,16" Spacing="12">
            <Button x:Name="AddNodeButton" Click="AddNode_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE710;" FontSize="16"/>
                    <TextBlock Text="添加节点"/>
                </StackPanel>
            </Button>
            <Button x:Name="RefreshButton" Click="Refresh_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72C;" FontSize="16"/>
                    <TextBlock Text="刷新"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- 主内容区域 -->
        <Grid Grid.Row="1" Padding="20,0,20,20">
            <ProgressRing x:Name="LoadingRing" IsActive="False" Width="50" Height="50" HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <StackPanel x:Name="EmptyState" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <FontIcon Glyph="&#xE968;" FontSize="48" Foreground="{ThemeResource SystemControlDisabledBaseMediumLowBrush}"/>
                <TextBlock Text="暂无节点" FontSize="18" Foreground="{ThemeResource SystemControlDisabledBaseMediumLowBrush}"/>
                <TextBlock Text="点击上方添加节点按钮开始" FontSize="14" Foreground="{ThemeResource SystemControlDisabledBaseMediumLowBrush}"/>
            </StackPanel>

            <ListView x:Name="NodesListView" 
                      ItemsSource="{x:Bind ViewModel.Nodes, Mode=OneWay}"
                      ItemTemplate="{StaticResource NodeTemplate}"
                      SelectionMode="None">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,4"/>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>
        </Grid>
    </Grid>
</Page>
