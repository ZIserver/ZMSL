<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ZMSL.App.Views.FileEditorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="40,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Click="Back_Click" Padding="12,8" Margin="0,0,20,0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                        <TextBlock Text="返回"/>
                    </StackPanel>
                </Button>

                <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="4">
                    <TextBlock x:Name="FileNameText" Text="未命名文件" 
                               FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock x:Name="FilePathText" Text="" 
                               FontSize="12" Opacity="0.6"/>
                </StackPanel>

                <Button Grid.Column="2" Click="Save_Click" Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE74E;" FontSize="14"/>
                        <TextBlock Text="保存"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- 编辑区域 -->
        <Border Grid.Row="1" Background="{ThemeResource LayerFillColorDefaultBrush}" Padding="40,24">
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                    CornerRadius="12" Padding="20">
                <ScrollViewer VerticalScrollBarVisibility="Auto" 
                              HorizontalScrollBarVisibility="Auto">
                    <TextBox x:Name="ContentTextBox"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas"
                             FontSize="14"
                             Padding="12"
                             BorderThickness="0"
                             Background="Transparent"
                             PlaceholderText="文件内容..."
                             MinHeight="400"
                             TextChanged="ContentTextBox_TextChanged"/>
                </ScrollViewer>
            </Border>
        </Border>

        <!-- 底部状态栏 -->
        <Border Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                BorderThickness="0,1,0,0" Padding="40,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusText" Text="就绪" Opacity="0.7" FontSize="12"/>
                <TextBlock Grid.Column="1" x:Name="CharCountText" Text="0 字符" 
                           Opacity="0.7" FontSize="12"/>
            </Grid>
        </Border>

        <!-- 加载指示器 -->
        <Grid x:Name="LoadingOverlay" Grid.RowSpan="3" 
              Background="{ThemeResource LayerFillColorDefaultBrush}" 
              Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                <ProgressRing IsActive="True" Width="48" Height="48"/>
                <TextBlock Text="正在处理..." FontSize="14" Opacity="0.7"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
