<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ZMSL.App.Views.RemoteServerDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题栏 -->
        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="40,20" CornerRadius="0,0,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="20">
                    <Button Click="Back_Click" Padding="12,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                            <TextBlock Text="返回"/>
                        </StackPanel>
                    </Button>
                    <StackPanel>
                        <TextBlock x:Name="ServerNameText" Text="服务器名称" FontSize="24" FontWeight="Bold"/>
                        <TextBlock x:Name="ServerTypeText" Text="加载中..." Opacity="0.7" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10">
                    <Button x:Name="StartButton" Click="Start_Click" Style="{StaticResource AccentButtonStyle}" Padding="16,8" IsEnabled="False">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE768;" FontSize="14"/>
                            <TextBlock Text="启动"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="StopButton" Click="Stop_Click" IsEnabled="False" Padding="16,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE71A;" FontSize="14"/>
                            <TextBlock Text="停止"/>
                        </StackPanel>
                    </Button>
                    <Button Content="重启" Click="Restart_Click" Padding="16,8"/>
                    <Button Content="文件管理" Click="FileManage_Click" Padding="16,8"/>
                    <Button Content="游戏设置" Click="GameSettings_Click" Padding="16,8"/>
                    <Button Content="服务器设置" Click="Settings_Click" Padding="16,8"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Row="1" Padding="40,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <!-- 控制台 -->
            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="12" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="控制台" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12"/>
                    <TextBox x:Name="ConsoleOutput" Grid.Row="1" FontFamily="Consolas" FontSize="12" IsReadOnly="True" TextWrapping="NoWrap" AcceptsReturn="True" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <TextBox.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="复制" Click="CopyConsole_Click">
                                    <MenuFlyoutItem.Icon>
                                        <SymbolIcon Symbol="Copy"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="全选" Click="SelectAllConsole_Click">
                                    <MenuFlyoutItem.Icon>
                                        <SymbolIcon Symbol="SelectAll"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutSeparator/>
                                <MenuFlyoutItem Text="AI 分析选中内容" Click="AnalyzeSelected_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE9D9;"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </TextBox.ContextFlyout>
                    </TextBox>
                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBox x:Name="CommandInput" 
                                 Grid.Column="0"
                                 PlaceholderText="输入命令..." 
                                 KeyDown="CommandInput_KeyDown"/>
                        
                        <Button Grid.Column="1" Content="发送" Margin="8,0,0,0" Click="SendCommand_Click"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- 右侧面板 -->
            <StackPanel Grid.Column="1" Margin="20,0,0,0" Spacing="16">
                <!-- 资源监控 -->
                <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="资源占用" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,16"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="CPU"/>
                            <ProgressBar x:Name="CpuProgressBar" Grid.Column="1" Value="0" Maximum="100"/>
                            <TextBlock x:Name="CpuText" Grid.Column="2" Text="0%" TextAlignment="Right"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="内存"/>
                            <ProgressBar x:Name="MemoryProgressBar" Grid.Column="1" Value="0" Maximum="100"/>
                            <TextBlock x:Name="MemoryText" Grid.Column="2" Text="0 MB" TextAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 在线玩家 -->
                <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <TextBlock Text="在线玩家" FontWeight="SemiBold" FontSize="16"/>
                            <TextBlock x:Name="PlayerCountText" Text="0/20" HorizontalAlignment="Right" Opacity="0.7"/>
                        </Grid>
                        <ListView x:Name="PlayerListView" MaxHeight="150">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4">
                                            <Button Content="OP" FontSize="11" Padding="6,2" Click="GiveOp_Click" Tag="{Binding}" ToolTipService.ToolTip="给予管理员权限"/>
                                            <Button Content="踢出" FontSize="11" Padding="6,2" Click="KickPlayer_Click" Tag="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <TextBlock x:Name="NoPlayersText" Text="暂无在线玩家" Opacity="0.5" HorizontalAlignment="Center" Margin="0,8"/>
                    </StackPanel>
                </Border>
                
                <!-- 备份管理 -->
                <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <TextBlock Text="备份管理" FontWeight="SemiBold" FontSize="16"/>
                            <Button Content="立即备份" Click="CreateBackup_Click" FontSize="12" Padding="8,4" HorizontalAlignment="Right"/>
                        </Grid>
                        
                        <ListView x:Name="BackupListView" MaxHeight="200" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <StackPanel>
                                            <TextBlock FontSize="13">
                                                <Run Text="{Binding Name}"/>
                                            </TextBlock>
                                            <TextBlock FontSize="11" Opacity="0.6">
                                                <Run Text="{Binding Size}"/> bytes
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4">
                                            <Button Content="删除" FontSize="11" Padding="6,2" Click="DeleteBackup_Click" Tag="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        
                        <TextBlock x:Name="NoBackupsText" Text="暂无备份" Opacity="0.5" HorizontalAlignment="Center" Margin="0,8"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- 加载指示器 -->
        <Grid Grid.Row="1" Background="{ThemeResource LayerFillColorDefaultBrush}" 
              x:Name="LoadingOverlay" Visibility="Collapsed">
            <ProgressRing IsActive="True" Width="48" Height="48"/>
        </Grid>
    </Grid>
</Page>
