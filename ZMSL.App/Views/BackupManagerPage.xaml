<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ZMSL.App.Views.BackupManagerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题栏 -->
        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="40,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="20">
                    <Button Click="Back_Click" Padding="12,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                            <TextBlock Text="返回"/>
                        </StackPanel>
                    </Button>
                    <StackPanel>
                        <TextBlock Text="备份管理" FontSize="24" FontWeight="Bold"/>
                        <TextBlock x:Name="ServerNameText" Text="服务器名称" Opacity="0.7" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="2" Content="立即备份" Click="CreateBackup_Click" Style="{StaticResource AccentButtonStyle}" Padding="16,8"/>
            </Grid>
        </Border>

        <!-- 备份列表 -->
        <ScrollViewer Grid.Row="1" Padding="40,24">
            <StackPanel Spacing="16">
                <TextBlock x:Name="NoBackupsText" Text="暂无备份记录" Opacity="0.5" HorizontalAlignment="Center" Margin="0,40" FontSize="16" Visibility="Collapsed"/>
                
                <ItemsControl x:Name="BackupItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" 
                                    CornerRadius="12" 
                                    Padding="24" 
                                    Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Spacing="8">
                                        <TextBlock FontSize="16" FontWeight="SemiBold">
                                            <Run Text="备份时间: "/>
                                            <Run Text="{Binding CreatedAt}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="14" Opacity="0.7">
                                            <Run Text="文件大小: "/>
                                            <Run Text="{Binding FileSizeBytes}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="13" Opacity="0.6">
                                            <Run Text="备份路径: "/>
                                            <Run Text="{Binding BackupPath}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                        <Button Content="恢复备份" Click="RestoreBackup_Click" Tag="{Binding}" Padding="16,8"/>
                                        <Button Content="删除" Click="DeleteBackup_Click" Tag="{Binding}" Padding="16,8"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
