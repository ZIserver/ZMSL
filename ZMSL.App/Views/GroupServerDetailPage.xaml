<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ZMSL.App.Views.GroupServerDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ZMSL.App.Views"
    xmlns:vm="using:ZMSL.App.ViewModels"
    xmlns:converters="using:ZMSL.App.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded">

    <Page.Resources>
        <converters:BoolToBrushConverter x:Key="SelectedBorderConverter" 
                                         TrueBrush="{ThemeResource SystemControlHighlightAccentBrush}"
                                         FalseBrush="Transparent"/>
        <converters:BoolNegationConverter x:Key="BoolNegationConverter"/>
        <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToCollapsed" Invert="True"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题栏 -->
        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="40,20" CornerRadius="0,0,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="20">
                    <Button Click="Back_Click" Padding="12,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                            <TextBlock Text="返回"/>
                        </StackPanel>
                    </Button>
                    <StackPanel>
                        <TextBlock Text="{x:Bind ViewModel.ServerName, Mode=OneWay}" FontSize="24" FontWeight="Bold"/>
                        <TextBlock Text="{x:Bind ViewModel.ServerStatus, Mode=OneWay}" Opacity="0.7" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10">
                    <Button Command="{x:Bind ViewModel.StartServerCommand}" IsEnabled="{x:Bind ViewModel.IsRunning, Converter={StaticResource BoolNegationConverter}, Mode=OneWay}" Style="{StaticResource AccentButtonStyle}" Padding="16,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE768;" FontSize="14"/>
                            <TextBlock Text="启动"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{x:Bind ViewModel.StopServerCommand}" IsEnabled="{x:Bind ViewModel.IsRunning, Mode=OneWay}" Padding="16,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE71A;" FontSize="14"/>
                            <TextBlock Text="停止"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{x:Bind ViewModel.RestartServerCommand}" IsEnabled="{x:Bind ViewModel.IsRunning, Mode=OneWay}" Padding="16,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                            <TextBlock Text="重启"/>
                        </StackPanel>
                    </Button>
                    <Button Content="子服务器" Click="ManageSubServers_Click" Padding="16,8"/>
                    <Button Content="文件管理" Click="ManageFiles_Click" Padding="16,8"/>
                    <Button Content="群组设置" Click="ShowConfigDialog_Click" Padding="16,8"/>
                    
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Row="1" Padding="40,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <!-- 控制台 -->
            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="12" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="控制台" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12"/>
                    
                    <TextBox x:Name="ConsoleOutput" 
                             Grid.Row="1" 
                             Text="{x:Bind ViewModel.ConsoleOutput, Mode=OneWay}"
                             FontFamily="Consolas" 
                             FontSize="12" 
                             IsReadOnly="True" 
                             TextWrapping="Wrap" 
                             AcceptsReturn="True" 
                             ScrollViewer.VerticalScrollBarVisibility="Auto" 
                             SelectionChanged="ConsoleOutput_SelectionChanged">
                        <TextBox.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="复制" Click="CopyConsole_Click">
                                    <MenuFlyoutItem.Icon>
                                        <SymbolIcon Symbol="Copy"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="全选" Click="SelectAllConsole_Click">
                                    <MenuFlyoutItem.Icon>
                                        <SymbolIcon Symbol="SelectAll"/>
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </TextBox.ContextFlyout>
                    </TextBox>
                    
                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBox x:Name="CommandInput" 
                                 Grid.Column="0"
                                 Text="{x:Bind ViewModel.CommandInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="输入命令..." 
                                 KeyDown="CommandInput_KeyDown" 
                                 TextChanged="CommandInput_TextChanged" 
                                 LostFocus="CommandInput_LostFocus"/>
                        
                        <Button Grid.Column="1" Content="发送" Margin="8,0,0,0" Command="{x:Bind ViewModel.SendCommandCommand}"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- 右侧面板 -->
            <StackPanel Grid.Column="1" Margin="20,0,0,0" Spacing="16">
                <!-- 资源监控 -->
                <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="资源占用" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,16"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="CPU"/>
                            <ProgressBar Value="{x:Bind ViewModel.CpuUsage, Mode=OneWay}" Maximum="100" Grid.Column="1"/>
                            <TextBlock Text="N/A" Grid.Column="2" TextAlignment="Right" Opacity="0.5"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="内存"/>
                            <ProgressBar Value="{x:Bind ViewModel.MemoryUsage, Mode=OneWay}" Maximum="100" Grid.Column="1"/>
                            <TextBlock Text="{x:Bind ViewModel.MemoryUsageText, Mode=OneWay}" Grid.Column="2" TextAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 玩家列表 -->
                <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <TextBlock Text="在线玩家" FontWeight="SemiBold" FontSize="16"/>
                            <TextBlock Text="{x:Bind ViewModel.PlayerCountText, Mode=OneWay}" HorizontalAlignment="Right" Opacity="0.7"/>
                        </Grid>
                        
                        <ListView ItemsSource="{x:Bind ViewModel.Players, Mode=OneWay}" MaxHeight="150">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Server}" VerticalAlignment="Center" HorizontalAlignment="Right" Opacity="0.5" FontSize="12" Margin="0,0,8,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <TextBlock Text="暂无在线玩家" Visibility="{x:Bind ViewModel.Players.Count, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=Invert, Mode=OneWay}" Opacity="0.5" HorizontalAlignment="Center" Margin="0,8"/>
                    </StackPanel>
                </Border>

                <!-- 子服务器列表 -->
                <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <TextBlock Text="子服务器" FontWeight="SemiBold" FontSize="16"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                <Button Content="一键启动" FontSize="12" Padding="8,4" Command="{x:Bind ViewModel.StartAllSubServersCommand}" Style="{StaticResource AccentButtonStyle}" ToolTipService.ToolTip="启动所有已停止的子服务器"/>
                                <Button Content="保存配置" FontSize="12" Padding="8,4" Command="{x:Bind ViewModel.SaveConfigCommand}"/>
                            </StackPanel>
                        </Grid>
                        
                        <ListView ItemsSource="{x:Bind ViewModel.SubServers, Mode=OneWay}" MaxHeight="300" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:SubServerItem">
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Spacing="2">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{x:Bind DisplayName}" FontWeight="SemiBold" FontSize="14"/>
                                                <Border Background="{ThemeResource SystemAccentColorLight2}" CornerRadius="4" Padding="4,0" Visibility="{x:Bind IsTry, Converter={StaticResource BoolToVisibilityConverter}}" VerticalAlignment="Center">
                                                    <TextBlock Text="主城" FontSize="10" Foreground="White"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind Address}" FontSize="11" Opacity="0.6"/>
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                            <!-- Start Button -->
                                            <Button Padding="6,4" Command="{Binding ElementName=RootPage, Path=ViewModel.StartSubServerCommand}" CommandParameter="{x:Bind}"
                                                    Visibility="{x:Bind IsRunning, Converter={StaticResource BoolToCollapsed}, Mode=OneWay}"
                                                    ToolTipService.ToolTip="启动此子服务器">
                                                <FontIcon Glyph="&#xE768;" FontSize="12"/>
                                            </Button>
                                            
                                            <!-- Stop Button -->
                                            <Button Padding="6,4" Command="{Binding ElementName=RootPage, Path=ViewModel.StopSubServerCommand}" CommandParameter="{x:Bind}"
                                                    Visibility="{x:Bind IsRunning, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                                                    Background="#C42B1C" Foreground="White"
                                                    ToolTipService.ToolTip="停止此子服务器">
                                                <FontIcon Glyph="&#xE71A;" FontSize="12"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        
                        <TextBlock Text="提示: 只有本地存在的子服务器才能在此控制启动/停止。" Opacity="0.5" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"/>
                        
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
        
        <!-- 浮动命令建议 Popup -->
        <Popup x:Name="CommandSuggestionPopup" 
               Grid.RowSpan="2"
               IsLightDismissEnabled="False"
               IsOpen="False">
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Padding="4"
                    Width="500"
                    MaxHeight="300">
                <Border.Shadow>
                    <ThemeShadow />
                </Border.Shadow>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="SuggestionListView">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button HorizontalAlignment="Stretch" 
                                        HorizontalContentAlignment="Left"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="12,8"
                                        Click="SuggestionItem_Click"
                                        Tag="{Binding}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Command}" FontWeight="SemiBold" FontSize="13"/>
                                        <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Popup>

        <!-- Sub Server Selection Dialog -->
        <ContentDialog x:Name="SubServerSelectionDialog"
                       Title="选择子服务器"
                       PrimaryButtonText="确定"
                       CloseButtonText="取消"
                       PrimaryButtonClick="SubServerSelectionDialog_PrimaryButtonClick">
            <ScrollViewer MaxHeight="400" MinWidth="400">
                <ItemsControl ItemsSource="{x:Bind ViewModel.AvailableServers, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:SelectableServerItem">
                            <Button HorizontalAlignment="Stretch" 
                                    HorizontalContentAlignment="Stretch"
                                    Margin="0,0,0,5" Padding="0"
                                    Background="Transparent" BorderThickness="0"
                                    Click="ServerItem_Click" Tag="{x:Bind}">
                                <Border BorderThickness="2" CornerRadius="8" Padding="12"
                                        HorizontalAlignment="Stretch"
                                        BorderBrush="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource SelectedBorderConverter}}"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="2" HorizontalAlignment="Left">
                                            <TextBlock Text="{x:Bind DisplayName}" FontWeight="SemiBold" TextAlignment="Left"/>
                                            <TextBlock Text="{x:Bind Detail}" FontSize="12" Opacity="0.6" TextAlignment="Left"/>
                                            
                                            <RadioButton Content="设为主城" 
                                                         Margin="0,4,0,0"
                                                         IsChecked="{x:Bind IsMainLobby, Mode=OneWay}" 
                                                         GroupName="MainLobbyGroup"
                                                         FontSize="12"
                                                         Click="SetMainLobby_Click" 
                                                         Visibility="{x:Bind IsSelected, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}"
                                                         Tag="{x:Bind}"/>
                                        </StackPanel>
                                        <FontIcon Glyph="&#xE73E;" FontSize="16" 
                                                  Visibility="{x:Bind IsSelected, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" 
                                                  Foreground="{ThemeResource SystemControlHighlightAccentBrush}" 
                                                  Grid.Column="1" VerticalAlignment="Top" Margin="0,4,0,0"/>
                                    </Grid>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </ContentDialog>
    </Grid>
</Page>
