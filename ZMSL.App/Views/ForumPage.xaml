<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ZMSL.App.Views.ForumPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:ZMSL.App.Views"
    xmlns:vm="using:ZMSL.App.ViewModels"
    xmlns:dto="using:ZMSL.Shared.DTOs"
    xmlns:converters="using:ZMSL.App.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
    </Page.Resources>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Orientation="Horizontal" Spacing="16">
                <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                        CornerRadius="8" Width="48" Height="48">
                    <FontIcon Glyph="&#xE8F2;" FontSize="24" Foreground="White"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="用户论坛" FontSize="24" FontWeight="SemiBold"/>
                    <TextBlock Text="与其他玩家交流心得、分享经验" FontSize="14" Opacity="0.6"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                <!-- 站内信按钮 -->
                

                <!-- 个人资料按钮 -->
                <Button Command="{x:Bind ViewModel.NavigateToProfileCommand}" Style="{StaticResource DateTimePickerFlyoutButtonStyle}" Padding="4" ToolTipService.ToolTip="个人资料" Visibility="{x:Bind ViewModel.IsLoggedIn, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <PersonPicture DisplayName="{x:Bind ViewModel.CurrentUsername, Mode=OneWay}" 
                                 ProfilePicture="{x:Bind ViewModel.AvatarImage, Mode=OneWay}"
                                 Width="32" Height="32"/>
                </Button>

                <Button Command="{Binding CreateNewThreadCommand}" Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontSize="16"/>
                        <TextBlock Text="发布新帖"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 搜索和分类 -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- 分类标签 -->
            <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Categories}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="dto:ForumCategoryDto">
                            <Button Content="{x:Bind Name}" 
                                    Command="{Binding ElementName=RootPage, Path=DataContext.SwitchCategoryCommand}"
                                    CommandParameter="{x:Bind}"
                                    Style="{ThemeResource DateTimePickerFlyoutButtonStyle}"
                                    CornerRadius="16" Padding="16,6"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- 搜索框 -->
            <AutoSuggestBox Grid.Column="1" PlaceholderText="搜索帖子..."
                            Text="{Binding SearchKeyword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            QueryIcon="Find"
                            QuerySubmitted="AutoSuggestBox_QuerySubmitted"/>
        </Grid>

        <!-- 帖子列表 -->
        <ScrollViewer Grid.Row="2">
            <ItemsControl ItemsSource="{Binding Threads}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="dto:ForumPostDto">
                        <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                Margin="0,0,0,12" Padding="0" CornerRadius="8"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                Command="{Binding ElementName=RootPage, Path=DataContext.ViewThreadDetailsCommand}"
                                CommandParameter="{x:Bind Id}">
                            <Grid Padding="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- 标题和置顶标记 -->
                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                                    <Border Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                                            CornerRadius="4" Padding="6,2"
                                            Visibility="{Binding IsPinned, Converter={StaticResource BoolToVisibility}, FallbackValue=Collapsed}">
                                        <TextBlock Text="置顶" FontSize="12" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                    </Border>
                                    <TextBlock Text="{x:Bind Title}" FontSize="16" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <!-- 内容摘要 -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Bind Content}" 
                                           FontSize="14" Opacity="0.7" MaxLines="2" TextTrimming="CharacterEllipsis" Margin="0,0,0,12"/>

                                <!-- 底部信息 -->
                                <Grid Grid.Row="2" Grid.Column="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE77B;" FontSize="14" Opacity="0.6"/>
                                            <TextBlock Text="{x:Bind Username}" FontSize="12" Opacity="0.6"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE823;" FontSize="14" Opacity="0.6"/>
                                            <TextBlock Text="{x:Bind CreatedAt}" FontSize="12" Opacity="0.6"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>

                                <!-- 统计数据 -->
                                <StackPanel Grid.RowSpan="3" Grid.Column="1" VerticalAlignment="Center" Spacing="16" Orientation="Horizontal" Margin="16,0,0,0">
                                    <StackPanel Spacing="4" MinWidth="40">
                                        <FontIcon Glyph="&#xE8F3;" FontSize="16" Opacity="0.6"/>
                                        <TextBlock Text="{x:Bind ViewCount}" FontSize="12" Opacity="0.6" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4" MinWidth="40">
                                        <FontIcon Glyph="&#xE8BD;" FontSize="16" Opacity="0.6"/>
                                        <TextBlock Text="{x:Bind CommentCount}" FontSize="12" Opacity="0.6" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4" MinWidth="40">
                                        <FontIcon Glyph="&#xEB51;" FontSize="16" Opacity="0.6"/>
                                        <TextBlock Text="{x:Bind LikeCount}" FontSize="12" Opacity="0.6" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 分页控件 -->
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16">
                <Button Content="上一页" Command="{Binding PreviousPageCommand}"/>
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Opacity="0.6"/>
                <Button Content="下一页" Command="{Binding NextPageCommand}"/>
            </StackPanel>
        </Grid>

        <!-- 加载遮罩 -->
        <Grid Grid.RowSpan="4" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Opacity="0.8"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <ProgressRing Width="64" Height="64" IsActive="True"/>
        </Grid>
    </Grid>
</Page>
