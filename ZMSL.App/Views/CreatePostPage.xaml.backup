<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ZMSL.App.Views.CreatePostPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ZMSL.App.Views"
    xmlns:viewmodels="using:ZMSL.App.ViewModels"
    xmlns:dto="using:ZMSL.Shared.DTOs"
    Loaded="Page_Loaded">
    
    <Grid Padding="24" MaxWidth="800" HorizontalAlignment="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock 
                Grid.Column="0"
                Text="发布新帖"
                Style="{StaticResource TitleTextBlockStyle}"/>
            
            <Button
                Grid.Column="1"
                Content="&#xE72B;"
                FontFamily="Segoe MDL2 Assets"
                Style="{StaticResource SubtleButtonStyle}"
                Click="CancelButton_Click"/>
        </Grid>

        <!-- 表单内容 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20">
                
                <!-- 分区选择 -->
                <ComboBox
                    Header="选择分区"
                    ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                    DisplayMemberPath="Name"
                    PlaceholderText="请选择帖子分区"
                    HorizontalAlignment="Stretch"/>

                <!-- 标题输入 -->
                <TextBox
                    Header="标题"
                    Text="{x:Bind ViewModel.Title, Mode=TwoWay}"
                    PlaceholderText="请输入帖子标题（至少5个字符）"
                    MaxLength="100"
                    HorizontalAlignment="Stretch">
                    <TextBox.Footer>
                        <TextBlock 
                            Text="{x:Bind GetTitleValidationText(ViewModel.Title), Mode=OneWay}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{x:Bind GetValidationColor(ViewModel.Title.Length >= 5), Mode=OneWay}"/>
                    </TextBox.Footer>
                </TextBox>

                <!-- 内容输入 -->
                <TextBox
                    Header="内容"
                    Text="{x:Bind ViewModel.Content, Mode=TwoWay}"
                    PlaceholderText="请输入帖子内容（至少10个字符）"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    MinHeight="200"
                    MaxHeight="400"
                    HorizontalAlignment="Stretch">
                    <TextBox.Footer>
                        <TextBlock 
                            Text="{x:Bind GetContentValidationText(ViewModel.Content), Mode=OneWay}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{x:Bind GetValidationColor(ViewModel.Content.Length >= 10), Mode=OneWay}"/>
                    </TextBox.Footer>
                </TextBox>

                <!-- 发布提示 -->
                <InfoBar
                    IsOpen="True"
                    Severity="Informational"
                    Title="发布须知"
                    Message="请遵守社区规范，文明发言。发布的内容需符合相关法律法规。"/>
            </StackPanel>
        </ScrollViewer>

        <!-- 底部按钮 -->
        <Grid Grid.Row="2" Margin="0,24,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel 
                Grid.Column="0" 
                Orientation="Horizontal" 
                Spacing="12" 
                VerticalAlignment="Center">
                <ProgressRing
                    IsActive="{x:Bind ViewModel.IsSubmitting, Mode=OneWay}"
                    Width="20"
                    Height="20"/>
                <TextBlock 
                    Text="正在发布..."
                    Style="{StaticResource CaptionTextBlockStyle}"
                    VerticalAlignment="Center"
                    Visibility="{x:Bind ViewModel.IsSubmitting, Mode=OneWay}"/>
            </StackPanel>

            <Button
                Grid.Column="1"
                Content="取消"
                Style="{StaticResource SubtleButtonStyle}"
                Click="CancelButton_Click"
                Margin="0,0,12,0"/>

            <Button
                Grid.Column="2"
                Content="发布"
                Style="{StaticResource AccentButtonStyle}"
                Click="SubmitButton_Click"
                IsEnabled="{x:Bind ViewModel.IsValid, Mode=OneWay}"/>
        </Grid>
    </Grid>
</Page>